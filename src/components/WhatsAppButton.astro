---
// Reusable WhatsApp click-to-chat button. This mirrors how Robert actually
// works — the call or message leads to "send me a photo and your postcode" —
// so the prefilled message asks for exactly that, and the cursor lands on the
// labelled gaps (WhatsApp places the caret at the end of the text).
//
// The attribution line is a plain sentence, not a tracking code: a wa.me tap
// leaves the site, so nothing client-side can see what happens next. The
// attribution travels inside the message and arrives where the enquiry lands.
import { DETAILS } from "../constants/details";

interface Props {
  message?: string;
  label?: string;
  variant?: "solid" | "outline";
  class?: string;
}

const {
  message = `Hi Robert, I'd like to ask about fire door work. Happy to send photos if that helps.

Enquiry via the Coulsy Fire Doors website.

Postcode:
What's involved:`,
  label = "WhatsApp",
  variant = "solid",
  class: className = "",
} = Astro.props;

// wa.me needs the number in international form, digits only: drop the leading 0,
// prefix the UK country code.
const waNumber = DETAILS.COMPANY.PHONE.replace(/\D/g, "").replace(/^0/, "44");
const href = `https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`;

const base =
  "inline-flex items-center justify-center gap-2 min-h-[52px] px-6 py-3 rounded-lg font-semibold text-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[#25D366]";
const styles =
  variant === "solid"
    ? "bg-[#25D366] text-white hover:bg-[#1ebe5d] shadow-md"
    : "border-2 border-[#25D366] text-[#0f7a4d] hover:bg-[#25D366]/10";
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${label} — opens WhatsApp in a new tab`}
  class={`${base} ${styles} ${className}`}
>
  <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.372-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
    ></path>
  </svg>
  {label}
</a>
