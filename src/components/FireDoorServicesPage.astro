---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import NearbyAreas from "./NearbyAreas.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import QualificationCard from "../components/QualificationCard.astro";
import { getFormattedPageData } from "../utils/pageMeta";

interface Props {
  location?: string;
  type?: string;
}

const { location, type } = Astro.props;

const {
  formattedServiceName,
  locationInText,
  cleanLocationName,
  businessSchema,
  localBusinessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedDescription,
} = getFormattedPageData(location, type);

const finalDescription = enhancedDescription || defaultDescription;
---

<Layout
  title={`${formattedServiceName} ${cleanLocationName ? `in ${cleanLocationName}` : "in Yorkshire"} | Professional Fire Door Solutions`}
  description={finalDescription}
  classes="mt-8 mb-16"
  location={location}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(businessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />
  <!-- Breadcrumb -->
  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Fire Door Services", href: "/fire-door-services" },
          ...(cleanLocationName
            ? [{ label: cleanLocationName, current: true }]
            : []),
        ]}
      />
    </div>
  </section>

  <ServiceHero
    title={`Comprehensive Fire Door Services${location ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
    description="Professional fire door services covering inspection, installation, maintenance, and compliance. From initial assessment to ongoing support, we provide complete fire safety solutions."
    primaryCta={{ text: "Get Services Quote", link: "#contact" }}
    secondaryCta={{ text: "Contact Us", link: "/contact" }}
  />

  <!-- Why Choose Our Services Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Why Choose Our Fire Door Services
        </h2>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <FeatureCard
            title="Complete Service Range"
            description="From initial inspection to installation and ongoing maintenance, we provide comprehensive fire door services to meet all your fire safety requirements."
          />

          <FeatureCard
            title="Expert Knowledge"
            description="35+ years of experience in fire safety, with qualified expertise in all aspects of fire door compliance and installation."
          />

          <FeatureCard
            title="Regulatory Compliance"
            description="All services comply with Building Regulations, RRO 2005, and British Standards to ensure your fire safety systems meet legal requirements."
          />

          <FeatureCard
            title="Local Service"
            description={`Serving ${cleanLocationName} and surrounding areas with prompt, reliable service and local knowledge of building requirements and regulations.`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Fire Door Services Overview
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServiceCard
            icon="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            iconColor="blue"
            title="Fire Door Inspections"
            description="Comprehensive fire door inspections to assess compliance and identify safety issues."
            features={[
              "Initial inspections",
              "Regular 6-monthly checks",
              "Compliance verification",
              "Detailed reporting",
            ]}
          />

          <ServiceCard
            icon="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
            iconColor="green"
            title="Fire Door Installation"
            description="Professional installation of fire doors and hardware to meet regulatory standards."
            features={[
              "New build installation",
              "Retrofit projects",
              "Hardware fitting",
              "Certification",
            ]}
          />

          <ServiceCard
            icon={[
              "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
              "M15 12a3 3 0 11-6 0 3 3 0 016 0z",
            ]}
            iconColor="purple"
            title="Fire Door Maintenance"
            description="Ongoing maintenance and repair services to keep fire doors compliant and functional."
            features={[
              "Regular servicing",
              "Repairs & replacements",
              "Emergency callouts",
              "Maintenance contracts",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            iconColor="orange"
            title="Compliance Services"
            description="Expert guidance and services to ensure fire safety compliance and certification."
            features={[
              "Regulatory guidance",
              "Certification support",
              "Documentation",
              "Training advice",
            ]}
          />

          <ServiceCard
            icon="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"
            iconColor="red"
            title="Emergency Services"
            description="24/7 emergency callout service for urgent fire door repairs and safety issues."
            features={[
              "24/7 emergency callouts",
              "Rapid response",
              "Safety assessments",
              "Temporary measures",
            ]}
          />

          <ServiceCard
            icon="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            iconColor="indigo"
            title="Consultancy"
            description="Expert consultancy services for fire safety planning and project management."
            features={[
              "Project planning",
              "Specification advice",
              "Risk assessments",
              "Technical support",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Service Process Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Service Process
        </h2>

        <div class="space-y-8">
          <ProcessStep
            number={1}
            title="Initial Consultation"
            description="We begin with a comprehensive consultation to understand your fire safety requirements and assess your current fire door situation."
          />

          <ProcessStep
            number={2}
            title="Assessment & Planning"
            description="Detailed assessment of your fire doors and development of a comprehensive service plan tailored to your specific needs."
          />

          <ProcessStep
            number={3}
            title="Service Delivery"
            description="Professional delivery of the required services with attention to detail and compliance with all relevant regulations and standards."
          />

          <ProcessStep
            number={4}
            title="Ongoing Support"
            description="Continued support and maintenance to ensure your fire doors remain compliant and functional for the long term."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Qualifications & Experience
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <QualificationCard
            title="Professional Qualifications"
            items={[
              "FireQual Fire Door Inspector",
              "CSCS Gold Card Holder",
              "35+ Years Experience",
              "Fully Insured",
            ]}
          />

          <QualificationCard
            title="Standards & Compliance"
            items={[
              "Building Regulations Approved Document B",
              "RRO 2005 Compliance",
              "BS 9999:2017 Standards",
              "BS 8214:2016 Fire Door Assemblies",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Nearby Areas Section -->
  <section class="relative z-10 mx-auto">
    <NearbyAreas location={location} serviceType="fire-door-services" />
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Get Your Fire Door Services Quote
        </h2>
        <ContactForm
          location={location}
          serviceType={type}
          uniqueId={location}
        />
      </div>
    </div>
  </section>
</Layout>
