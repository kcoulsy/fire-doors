---
interface Props {
  icon: string | string[]; // SVG path data (single path or array of paths)
  iconColor?: "brand" | "blue" | "green" | "purple" | "orange" | "red" | "indigo";
  title: string;
  description: string;
  features?: string[];
}

const {
  icon,
  // One consistent Fire Doors treatment. The old default was a per-card rainbow
  // of bootstrap hues; the brand navy chip is now the default and the only
  // value the service pages pass.
  iconColor = "brand",
  title,
  description,
  features = [],
} = Astro.props;

// Normalize icon to array
const iconPaths = Array.isArray(icon) ? icon : [icon];

// Color mapping for icon backgrounds and text
const colorClasses = {
  brand: {
    bg: "bg-brand-50",
    text: "text-brand-700",
  },
  blue: {
    bg: "bg-blue-100",
    text: "text-blue-600",
  },
  green: {
    bg: "bg-green-100",
    text: "text-green-600",
  },
  purple: {
    bg: "bg-purple-100",
    text: "text-purple-600",
  },
  orange: {
    bg: "bg-orange-100",
    text: "text-orange-600",
  },
  red: {
    bg: "bg-red-100",
    text: "text-red-600",
  },
  indigo: {
    bg: "bg-indigo-100",
    text: "text-indigo-600",
  },
};

const colors = colorClasses[iconColor];
---

<div
  class="bg-white p-6 rounded-lg shadow-sm hover:shadow-lg transition-shadow"
>
  <div
    class={`w-12 h-12 ${colors.bg} rounded-lg flex items-center justify-center mb-4`}
  >
    <svg
      class={`w-6 h-6 ${colors.text}`}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      xmlns="http://www.w3.org/2000/svg"
    >
      {iconPaths.map((path) => (
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d={path}
        />
      ))}
    </svg>
  </div>
  <h3 class="text-xl font-semibold text-brand-900 mb-3">{title}</h3>
  <p class="text-gray-600 mb-4">{description}</p>
  {features.length > 0 && (
    <ul class="text-sm text-gray-600 space-y-1">
      {features.map((feature) => (
        <li>• {feature}</li>
      ))}
    </ul>
  )}
</div>

