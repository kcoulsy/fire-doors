---
interface Props {
  title: string;
  description: string;
  primaryCta?: {
    text: string;
    link: string;
  };
  secondaryCta?: {
    text: string;
    link: string;
  };
}

const {
  title,
  description,
  primaryCta = { text: "Get Quote", link: "#contact" },
  secondaryCta = { text: "Contact Us", link: "/contact" },
} = Astro.props;
---

<!-- Hero Section -->
<section class="bg-gradient-to-br from-brand-50 to-white py-10 lg:py-14">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl lg:text-5xl font-bold text-brand-900 mb-6">
        {title}
      </h1>
      <p class="text-xl text-gray-600 mb-6 leading-relaxed">
        {description}
      </p>
      
      <!-- Prominent Phone Number -->
      <div class="mb-8">
        <a
          href="tel:07544030486"
          class="inline-flex items-center justify-center px-6 py-3 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-800 transition-colors duration-200 text-lg shadow-md"
        >
          <svg
            class="mr-2 w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            />
          </svg>
          Call Now: 07544 030486
        </a>
        <p class="text-sm text-gray-500 mt-2">Available for quotes and enquiries</p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={primaryCta.link}
          class="inline-flex items-center justify-center px-8 py-4 bg-brand text-white font-semibold rounded-lg hover:bg-brand-light transition-colors duration-200"
        >
          {primaryCta.text}
          <svg
            class="ml-2 w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href={secondaryCta.link}
          class="inline-flex items-center justify-center px-8 py-4 border border-gray-300 text-gray-700 font-semibold rounded-lg hover:bg-gray-50 transition-colors duration-200"
        >
          {secondaryCta.text}
        </a>
      </div>
    </div>
  </div>
</section>

