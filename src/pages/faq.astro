---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import FAQSchema from "../components/FAQSchema.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const faqData = [
  {
    category: "General Fire Door Services",
    questions: [
      {
        question: "What fire door services do you provide?",
        answer:
          "We provide comprehensive fire door services including installation, maintenance, inspections, repairs, and compliance certification. Our services cover both domestic and commercial properties across Yorkshire.",
      },
      {
        question: "How long have you been providing fire door services?",
        answer:
          "I've been on the tools since 1988. I passed the FireQual fire door inspection exams in December 2024 and now specialise in fire door work.",
      },
      {
        question: "Do you work on both domestic and commercial properties?",
        answer:
          "Yes, we work on both domestic and commercial properties. From residential fire door installations to commercial fire safety compliance, we provide the same high-quality service for all types of properties.",
      },
      {
        question: "What areas do you cover?",
        answer:
          "We cover Yorkshire and surrounding areas including York, Leeds, Harrogate, Ripon, Wetherby, Selby, and many more locations within approximately 20 miles of York.",
      },
    ],
  },
  {
    category: "Fire Door Installation",
    questions: [
      {
        question: "How much does fire door installation cost?",
        answer:
          "Fire door installation costs vary depending on the type of door, frame requirements, hardware needed, and project complexity. We provide detailed quotes after assessing your specific requirements. Contact us for a consultation and quote.",
      },
      {
        question: "How long does fire door installation take?",
        answer:
          "Installation time depends on the number of doors and complexity. A single fire door typically takes 2-4 hours, while larger projects may take 1-2 days. We'll provide a detailed timeline during the quote process.",
      },
      {
        question: "Do you provide fire door frames as well?",
        answer:
          "Yes, we provide complete fire door solutions including frames, hardware, and all necessary components to ensure full compliance with fire safety regulations.",
      },
      {
        question: "Can you install fire doors in existing buildings?",
        answer:
          "Yes, we specialise in retrofitting fire doors in existing buildings. We assess the current structure and recommend the best approach for compliance and safety.",
      },
    ],
  },
  {
    category: "Fire Door Maintenance",
    questions: [
      {
        question: "How often should fire doors be maintained?",
        answer:
          "Fire doors should be maintained at least every 6 months according to fire safety regulations. Regular maintenance ensures compliance and optimal performance in case of a fire emergency.",
      },
      {
        question: "What does fire door maintenance include?",
        answer:
          "Our maintenance service includes checking door operation, inspecting seals and hardware, testing self-closing devices, verifying signage, and ensuring all components meet current fire safety standards.",
      },
      {
        question: "Do you provide emergency repair services?",
        answer:
          "Yes, we provide emergency callout services for urgent fire door repairs. Contact us immediately if you have a fire door that's not functioning properly.",
      },
      {
        question: "How much does fire door maintenance cost?",
        answer:
          "Maintenance costs depend on the number of doors and their condition. We offer competitive rates and can provide maintenance contracts for regular servicing. Contact us for a quote.",
      },
    ],
  },
  {
    category: "Fire Door Inspections",
    questions: [
      {
        question: "How often should fire doors be inspected?",
        answer:
          "Fire doors should be inspected at least every 6 months, though some high-traffic areas may require more frequent inspections. We can assess your specific needs and recommend an appropriate inspection schedule.",
      },
      {
        question: "What qualifications do you have?",
        answer:
          "I'm a FireQual Fire Door Inspector, certified in December 2024, with 35+ years in the trade behind it as a City & Guilds qualified joiner. I'm qualified to handle all aspects of fire door inspections and compliance.",
      },
      {
        question: "Do you provide certificates or reports?",
        answer:
          "Yes. Every inspection comes with a written summary and photographic evidence suitable for your Fire Risk Assessment record. Full certification documentation can be issued on completion of remedial works if required. All reports document the condition of each fire door, any issues found, and recommendations for repairs or improvements to ensure compliance.",
      },
      {
        question: "What happens if fire doors fail inspection?",
        answer:
          "If fire doors fail inspection, we provide a detailed report outlining the issues and recommend the necessary repairs or replacements. We can then carry out the required work to bring the doors up to compliance standards.",
      },
      {
        question: "How much does a domestic apartment entrance fire door inspection cost?",
        answer:
          "Standard domestic fire-door surveys start from £50 + VAT for one door. That covers attendance and inspection of the door and frame, the relevant measurements and observations, an assessment of whether repair or replacement looks appropriate, written findings, and the information needed to price any remedial work — carried out by a qualified fire door joiner (FireQual Certified). Additional doors are not automatically charged at £50 each; they are priced according to quantity, location and scope. Where the property is outside my normal local operating area, travel and mobilisation is added as a separate quoted line. Parking, access charges and other site-specific expenses may also apply. Every additional charge is confirmed in your quotation before the survey is booked. FRA (Fire Risk Assessment) reports often flag 'issues', but they rarely give the specific measurements, door types or certification details needed to quote accurately, so I need to inspect in person to make sure you get the right solution first time, not guesswork. Most fire doors fail on small, correctable issues — the survey identifies these so repairs can be priced efficiently without unnecessary replacement.",
      },
      {
        question: "What if I don't have an FRA report but need my door checked?",
        answer:
          "No problem. We can provide a stand-alone fire door compliance inspection, giving you the same professional assessment and report you can forward to your building manager or insurance provider. This is ideal for landlords, small business owners, or residential blocks where no recent FRA has been completed. Contact us to discuss pricing for this service and what's included in the inspection.",
      },
    ],
  },
  {
    category: "Pricing and Quotes",
    questions: [
      {
        question: "Do you provide quotes?",
        answer:
          "Yes, we provide detailed quotes for all our services. We'll assess your requirements and provide a comprehensive quote including all necessary work, materials, and compliance certification.",
      },
      {
        question: "Why is there a charge for inspections?",
        answer:
          "Standard domestic fire-door surveys start from £50 + VAT because this is a technical compliance service, not just a sales visit. Each survey involves certified measurement tools, regulatory assessment (BS 8214 and BS EN 1634-1), and professional judgement — which protects you legally and financially. Charging for it means you receive an independent, accurate assessment, not a rushed 'quote visit'. Where expressly stated in the remedial quotation, the £50 survey fee may be credited against subsequent remedial work. Travel, parking and other site-specific charges are not credited. For commercial properties and other services, pricing is structured differently. Contact me to discuss your requirements and receive a tailored quote.",
      },
      {
        question: "How much does a commercial fire door inspection cost?",
        answer:
          "Commercial inspections are priced by the number of doors and site complexity. For guidance: Small premises (under 10 doors): from £180 + VAT. Medium sites (10–30 doors): typically £15–£25 per door. Large multi-site or volume inspections: quoted individually, with volume discounts available. All commercial inspections include a full digital report with photographs, compliance notes, and remedial recommendations — suitable for FRA updates or insurance compliance. Contact us with your property details for a tailored commercial inspection quote.",
      },
      {
        question: "How much does fire door installation cost?",
        answer:
          "Fire door installation costs vary depending on the type of door, frame requirements, hardware needed, and project complexity. Factors include whether it's a new installation or retrofit, door specifications, accessibility, and compliance requirements. Commercial installations are typically priced differently from domestic installations due to scale and complexity. We provide detailed quotes after assessing your specific requirements. Contact us for a consultation and quote.",
      },
      {
        question: "How much does fire door maintenance cost?",
        answer:
          "Maintenance costs depend on the number of doors, their condition, and whether the property is domestic or commercial. We offer competitive rates and can provide maintenance contracts for regular servicing, which are often more cost-effective for multiple doors or commercial properties. Commercial maintenance contracts are typically structured differently to accommodate larger properties and more frequent inspection schedules. Contact us for a quote tailored to your specific needs.",
      },
      {
        question: "Do you offer maintenance contracts?",
        answer:
          "Yes, we offer maintenance contracts for regular fire door servicing. This ensures your fire doors remain compliant and in optimal condition throughout the year. Maintenance contracts are available for both domestic and commercial properties, with pricing structured according to the number of doors, inspection frequency, and specific requirements. Commercial contracts often include volume discounts and priority service. Contact us to discuss a maintenance contract tailored to your needs.",
      },
      {
        question: "How much do emergency callouts cost?",
        answer:
          "Emergency callout costs vary depending on the nature of the emergency, time of day, location, and whether it's a domestic or commercial property. Commercial emergency callouts are typically priced differently due to the complexity and scale of commercial fire door systems. We aim to respond to emergency callouts within 24 hours, and often much sooner. Contact us immediately for urgent fire door issues and we'll provide transparent pricing based on your specific emergency situation.",
      },
      {
        question: "Is there a minimum charge for remedial or repair work?",
        answer:
          "Remedial works may be subject to a minimum half-day or full-day attendance, depending on the location, scope and resources required. Any minimum attendance and associated travel or site-specific charges will be clearly stated in the quotation before work is booked. This is separate from the domestic survey fee, which starts from £50 + VAT for one door.",
      },
      {
        question: "What payment methods do you accept?",
        answer:
          "We accept bank transfers and cash. Payment terms are discussed during the quote process and are typically due upon completion of work. For commercial clients, we can arrange invoicing and payment terms that suit your business needs. All quotes include a full breakdown of materials, labour, and VAT for complete transparency. Contact us to discuss payment options.",
      },
      {
        question: "Do you charge VAT?",
        answer:
          "Yes, all my services are subject to VAT where applicable. Standard domestic fire-door surveys start from £50 plus VAT for one door, excluding any travel, parking or other site-specific charges, which are confirmed in your quotation before attendance. For commercial clients and other services, VAT will be clearly indicated on all quotes. All final quotes include a full breakdown of materials, labour, and VAT for complete transparency.",
      },
      {
        question: "What guarantees do you offer?",
        answer:
          "I carry out every installation and repair myself — FireQual certified, fully insured, and working to BS 8214 and BM Trada / Certifire standards where applicable. Every completed door set is issued with a record sheet and photographic evidence to demonstrate compliance. I stand behind my work, with 35+ years in joinery and small-build behind it.",
      },
    ],
  },
  {
    category: "Emergency Services",
    questions: [
      {
        question: "Do you provide emergency callout services?",
        answer:
          "Yes, we provide emergency callout services for urgent fire door repairs and safety issues. Contact us immediately if you have a fire door that's not functioning properly.",
      },
      {
        question: "How quickly can you respond to emergencies?",
        answer:
          "We aim to respond to emergency callouts within 24 hours, and often much sooner depending on the nature of the emergency and your location.",
      },
      {
        question: "What constitutes a fire door emergency?",
        answer:
          "Fire door emergencies include doors that won't close properly, damaged seals, broken hardware, or any issue that compromises the door's ability to function in a fire emergency.",
      },
    ],
  },
];

// Flatten all questions for schema
const allFaqs = faqData.flatMap((category) => category.questions);

// SEO data
const seoData = {
  title:
    "Fire Door FAQ - Common Questions About Fire Door Services | Coulsy Fire Doors",
  description:
    "Get answers to common questions about fire door installation, maintenance, inspections, and compliance. Expert fire door services in Yorkshire from a FireQual certified inspector.",
  keywords:
    "fire door FAQ, fire door questions, fire door installation, fire door maintenance, fire door inspection, fire safety compliance, Yorkshire fire doors",
};
---

<Layout
  title={seoData.title}
  description={seoData.description}
  classes="mb-16"
>
  <!-- Breadcrumb -->
  <section class="bg-gray-50 pt-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Home", href: "/" },
          { label: "FAQ", current: true },
        ]}
      />
    </div>
  </section>

  <!-- FAQ Schema -->
  <FAQSchema
    faqs={allFaqs}
    pageTitle="Fire Door FAQ"
    pageDescription="Common questions about fire door services, installation, maintenance, and compliance"
  />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-brand to-brand-dark text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Frequently Asked Questions
      </h1>
      <p class="text-xl text-white/90 max-w-2xl mx-auto mb-8">
        Get answers to common questions about fire door services, installation,
        maintenance, and compliance. Can't find what you're looking for? Contact
        us directly.
      </p>
    </div>
  </section>

  <!-- FAQ Categories -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <!-- Category Navigation -->
        <div class="mb-12">
          <h2 class="text-3xl font-bold text-center text-brand-900 mb-8">
            Browse by Category
          </h2>
          <div class="flex flex-wrap justify-center gap-4">
            {
              faqData.map((category, index) => (
                <button
                  class="category-btn px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-brand hover:text-white transition-colors duration-200 font-medium"
                  data-category={index}
                >
                  {category.category}
                </button>
              ))
            }
          </div>
        </div>

        <!-- FAQ Content -->
        <div class="space-y-8">
          {
            faqData.map((category, categoryIndex) => (
              <div class="faq-category" data-category={categoryIndex}>
                <h3 class="text-2xl font-bold text-brand-900 mb-6 border-b border-gray-200 pb-4">
                  {category.category}
                </h3>
                {category.category === "Pricing and Quotes" && (
                  <div class="mb-8 p-6 bg-gray-50 rounded-lg border border-gray-200">
                    <h4 class="text-xl font-semibold text-brand-900 mb-3">
                      Fire Door Pricing & FAQ
                    </h4>
                    <p class="text-gray-700 mb-3">
                      Fire safety pricing shouldn't be confusing. Travel, mobilisation, parking, access and other site-specific charges are quoted separately where they apply.
                    </p>
                    <p class="text-gray-700 mb-3">
                      Below you'll find clear, transparent pricing information for my inspection, installation and maintenance services — all carried out by me, a FireQual certified fire door inspector with 35+ years in the trade.
                    </p>
                    <p class="text-gray-700">
                      Whether you're a homeowner, landlord, or commercial property manager, you'll know exactly what to expect before we begin.
                    </p>
                  </div>
                )}
                <div class="space-y-4">
                  {category.questions.map((item, questionIndex) => (
                    <div class="faq-item bg-white border border-gray-200 rounded-lg overflow-hidden shadow-sm">
                      <button
                        class="faq-question w-full px-6 py-4 text-left bg-gray-50 hover:bg-gray-100 transition-colors duration-200 flex justify-between items-center"
                        data-category={categoryIndex}
                        data-question={questionIndex}
                      >
                        <span class="font-medium text-gray-800">
                          {item.question}
                        </span>
                        <svg
                          class="faq-icon w-5 h-5 text-gray-500 transform transition-transform duration-200"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M19 9l-7 7-7-7"
                          />
                        </svg>
                      </button>
                      <div class="faq-answer hidden px-6 py-4 bg-white border-t border-gray-200">
                        <p class="text-gray-600 leading-relaxed">
                          {item.answer}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Contact Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-brand-900 mb-4">
          Ready to Book an Inspection or Request a Quote?
        </h2>
        <p class="text-xl text-gray-600 mb-4">
          Can't find the answer you're looking for? Contact us directly and
          we'll be happy to help.
        </p>
        <p class="text-lg text-gray-700 mb-8 font-medium">
          Call <a href="tel:07544030486" class="text-brand hover:text-brand-dark">07544 030486</a> or email <a href="mailto:robert@coulsy.co.uk" class="text-brand hover:text-brand-dark">robert@coulsy.co.uk</a>
        </p>
        <p class="text-gray-600 italic">
          Serving Yorkshire and surrounding areas — trusted by property managers, landlords, and building owners for reliable, compliant fire door services.
        </p>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold text-brand-900 mb-4">
              Get in Touch
            </h3>
            <div class="space-y-3 text-left">
              <div class="flex items-center">
                <svg
                  class="w-5 h-5 text-brand mr-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
                <span class="text-gray-600">07544 030486</span>
              </div>
              <div class="flex items-center">
                <svg
                  class="w-5 h-5 text-brand mr-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <span class="text-gray-600">robert@coulsy.co.uk</span>
              </div>
              <div class="flex items-center">
                <svg
                  class="w-5 h-5 text-brand mr-3"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span class="text-gray-600">Yorkshire & Surrounding Areas</span>
              </div>
            </div>
          </div>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold text-brand-900 mb-4">
              Quick Response
            </h3>
            <ul class="text-left space-y-2 text-gray-600">
              <li>• Professional consultations and quotes</li>
              <li>• Emergency callout service</li>
              <li>• Flexible appointment times</li>
              <li>• 35+ years in the trade</li>
              <li>• FireQual certified inspector</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Get Your Quote
        </h2>
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>

<script>
  // @ts-nocheck
  // FAQ functionality
  document.addEventListener("DOMContentLoaded", function () {
    const categoryBtns = document.querySelectorAll(".category-btn");
    const faqCategories = document.querySelectorAll(".faq-category");
    const faqQuestions = document.querySelectorAll(".faq-question");

    // Category filtering
    categoryBtns.forEach((btn) => {
      btn.addEventListener("click", function () {
        const categoryIndex = this.getAttribute("data-category");

        // Update active button
        categoryBtns.forEach((b) =>
          b.classList.remove("bg-brand", "text-white")
        );
        categoryBtns.forEach((b) =>
          b.classList.add("bg-gray-100", "text-gray-700")
        );
        this.classList.remove("bg-gray-100", "text-gray-700");
        this.classList.add("bg-brand", "text-white");

        // Show/hide categories
        faqCategories.forEach((category, index) => {
          if (categoryIndex === "all" || index === parseInt(categoryIndex)) {
            category.style.display = "block";
          } else {
            category.style.display = "none";
          }
        });
      });
    });

    // FAQ accordion
    faqQuestions.forEach((question) => {
      question.addEventListener("click", function () {
        const answer = this.nextElementSibling;
        const icon = this.querySelector(".faq-icon");

        // Toggle answer visibility
        answer.classList.toggle("hidden");

        // Rotate icon
        if (answer.classList.contains("hidden")) {
          icon.style.transform = "rotate(0deg)";
        } else {
          icon.style.transform = "rotate(180deg)";
        }
      });
    });

    // Show all categories by default
    categoryBtns[0].click();
  });
</script>
