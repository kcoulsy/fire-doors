---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import NearbyAreas from "./NearbyAreas.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import QualificationCard from "../components/QualificationCard.astro";
import { getFormattedPageData } from "../utils/pageMeta";

interface Props {
  location?: string;
  type?: string;
}

const { location, type } = Astro.props;

const {
  locationInText,
  cleanLocationName,
  businessSchema,
  localBusinessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedDescription,
} = getFormattedPageData(location, type);

const finalDescription = enhancedDescription || defaultDescription;
const place = cleanLocationName || "Yorkshire";
---

<Layout
  title={`Fire Door Maintenance${cleanLocationName ? ` in ${cleanLocationName}` : " in Yorkshire"} | Coulsy Fire Doors`}
  description={finalDescription}
  classes="mt-8 mb-16"
  location={location}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(businessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Fire Door Maintenance", href: "/fire-door-maintenance" },
          ...(cleanLocationName
            ? [{ label: cleanLocationName, current: true }]
            : []),
        ]}
      />
    </div>
  </section>

  <ServiceHero
    title={`Fire Door Maintenance${location ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
    description={`I'm Robert — a FireQual qualified fire door inspector covering ${place}. Most fire doors don't fail dramatically; they drift out of compliance — a seal comes off, a closer gets tired, a gap opens up. I'll come out, go door by door, and put it right before it becomes an enforcement issue.`}
    primaryCta={{ text: "Get a Maintenance Quote", link: "#contact" }}
    secondaryCta={{ text: "Contact Us", link: "/contact" }}
  />

  <!-- Why maintenance matters -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Why doors drift and why it matters
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Fire doors are mechanical — they get slammed, wedged open, hit
          with trolleys, and the seals get painted over. Six months of
          that and a door that passed its last inspection can be
          technically non-compliant. That's what maintenance catches.
        </p>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <FeatureCard
            title="6-monthly is the baseline"
            description="The Regulatory Reform (Fire Safety) Order expects fire doors to be checked at least every six months — more often for high-traffic commercial sites. Regular visits keep you compliant without the drama of a failed FRA."
          />

          <FeatureCard
            title="Catch the small stuff early"
            description="A £30 seal replacement is a lot cheaper than a failed inspection, an enforcement notice, or a full doorset swap. Most maintenance visits are small adjustments — the compounding kind that keeps doors out of trouble."
          />

          <FeatureCard
            title="Insurer and RP paper trail"
            description="Every visit gets a short written record — what was checked, what was done, photos where relevant. If your insurer or Responsible Person asks for evidence, you've got it."
          />

          <FeatureCard
            title={`Local to ${place}`}
            description={`I cover ${location ? `${place} and ` : ""}Yorkshire daily, so scheduled visits are easy to keep. Emergency jobs — closer gone, door damaged, won't shut — get fitted in where capacity allows.`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What maintenance covers -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          What a maintenance visit covers
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Real work on each door, not a tick-box exercise.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServiceCard
            icon="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
            iconColor="blue"
            title="Condition check"
            description="Every door on the contract looked at properly — leaf, frame, gaps, seals, hinges, closer, vision panel, ironmongery — against the same checklist used for a full inspection."
            features={[
              "Door by door, not spot-check",
              "Photos of anything borderline",
              "Gap & closer measurements recorded",
              "Written visit record",
            ]}
          />

          <ServiceCard
            icon={[
              "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
              "M15 12a3 3 0 11-6 0 3 3 0 016 0z",
            ]}
            iconColor="green"
            title="Seals, hinges, closers"
            description="The three things that fail most — intumescent and smoke seals, hinges, and door closers. I replace or adjust on the visit where I can, so most issues are resolved before I leave."
            features={[
              "Intumescent seal replacement",
              "Smoke seal replacement",
              "Closer adjustment or swap",
              "Hinge tightening / replacement",
            ]}
          />

          <ServiceCard
            icon="M13 10V3L4 14h7v7l9-11h-7z"
            iconColor="purple"
            title="Gap adjustment & rehanging"
            description="Gaps that have opened up past 3mm (head/jambs) or 8mm (threshold) lose the rating. I rehang, adjust or plane where needed so doors meet spec again."
            features={[
              "Head & jamb gap checks",
              "Threshold gap adjustment",
              "Rehanging dropped doors",
              "Minor timber repairs",
            ]}
          />

          <ServiceCard
            icon="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"
            iconColor="red"
            title="Urgent repairs"
            description="Closer sheared off, door damaged in a tenant incident, won't shut after a break-in — get in touch and I'll fit it in where I can. Make-safe same visit, full repair as soon as parts allow."
            features={[
              "Priority callout",
              "Temporary make-safe",
              "Full repair visit scheduled",
              "Parts sourced quickly",
            ]}
          />

          <ServiceCard
            icon="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            iconColor="orange"
            title="Maintenance contracts"
            description="Fixed-schedule 6- or 3-monthly contracts so you don't have to chase it. Works well for HMO portfolios, care homes, schools, and managed blocks."
            features={[
              "6-monthly or quarterly",
              "Priced per door, transparently",
              "Reminders before each visit",
              "Same inspector every time",
            ]}
          />

          <ServiceCard
            icon="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            iconColor="indigo"
            title="Visit records for your RP"
            description="After each visit you get a short written record — what I looked at, what I did, photos of anything I replaced. Goes straight into your building's fire safety file."
            features={[
              "Per-visit written record",
              "Photos of changed items",
              "Annotated action list",
              "Emailed same day",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- How maintenance runs -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          How a maintenance contract runs
        </h2>

        <div class="space-y-8">
          <ProcessStep
            number={1}
            title="Baseline visit first"
            description={`For a new contract I come to ${place}, log every door, and note its starting condition. You get that as a written baseline — useful if an insurer or enforcement officer ever asks what state the doors were in.`}
          />

          <ProcessStep
            number={2}
            title="Agree the schedule"
            description="6-monthly suits most buildings; 3-monthly for high-traffic commercial. I price per door, transparently, so you can see exactly what you're paying for. No surprise invoices at year-end."
          />

          <ProcessStep
            number={3}
            title="Each visit"
            description="I work through every door in a consistent order. Small stuff gets done on the visit — seals, closer adjustments, hinge tightening. Anything bigger gets quoted before I leave so you decide whether to proceed."
          />

          <ProcessStep
            number={4}
            title="Written record, same day"
            description="You get an email summary of the visit — doors checked, items replaced, anything recommended, photos. Add it to your building's fire safety file and you've got your paper trail."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Qualifications and standards
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          The bits that matter when an insurer or RP asks who's
          maintaining your doors.
        </p>

        <div class="grid md:grid-cols-2 gap-8">
          <QualificationCard
            title="My qualifications"
            items={[
              "FireQual Fire Door Inspector",
              "CSCS Gold Card holder",
              "City & Guilds qualified (since 1989)",
              "Fully insured, VAT registered",
            ]}
          />

          <QualificationCard
            title="Standards I work to"
            items={[
              "Approved Document B (Building Regs)",
              "Regulatory Reform (Fire Safety) Order 2005",
              "BS 8214:2016 — fire door assemblies",
              "BS 9999:2017 — fire safety in buildings",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 mx-auto">
    <NearbyAreas location={location} serviceType="fire-door-maintenance" />
  </section>

  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Get a quote
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Tell me the building type, roughly how many doors, and whether
          you've had a recent inspection — I'll come back with a sensible
          schedule and a per-door price.
        </p>
        <ContactForm
          location={location}
          serviceType={type}
          uniqueId={location}
        />
      </div>
    </div>
  </section>
</Layout>
