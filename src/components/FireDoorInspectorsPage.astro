---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import NearbyAreas from "./NearbyAreas.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import QualificationCard from "../components/QualificationCard.astro";
import { getFormattedPageData } from "../utils/pageMeta";

interface Props {
  location?: string;
  type?: string;
}

const { location, type } = Astro.props;

const {
  formattedServiceName,
  locationInText,
  cleanLocationName,
  businessSchema,
  localBusinessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedDescription,
} = getFormattedPageData(location, type);

const finalDescription = enhancedDescription || defaultDescription;
---

<Layout
  title={`${formattedServiceName} ${cleanLocationName ? `in ${cleanLocationName}` : "in Yorkshire"} | Professional Fire Door Inspections`}
  description={finalDescription}
  classes="mt-8 mb-16"
  location={location}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(businessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />
  <!-- Breadcrumb -->
  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Fire Door Inspectors", href: "/fire-door-inspectors" },
          ...(cleanLocationName
            ? [{ label: cleanLocationName, current: true }]
            : []),
        ]}
      />
    </div>
  </section>

  <ServiceHero
    title={`Fire Door Inspection Services${cleanLocationName ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
    description="Professional fire door inspection services to ensure your fire doors meet all regulatory requirements. Our qualified inspectors provide comprehensive assessments and detailed compliance reports."
    primaryCta={{ text: "Book Inspection", link: "#contact" }}
    secondaryCta={{ text: "Contact Us", link: "/contact" }}
  />

  <!-- Why Professional Inspections Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Why Professional Fire Door Inspections Matter
        </h2>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <FeatureCard
            title="Regulatory Compliance"
            description="The Regulatory Reform (Fire Safety) Order 2005 requires regular fire door inspections. Professional inspections ensure compliance and avoid legal penalties."
          />

          <FeatureCard
            title="Safety Assurance"
            description="Qualified inspectors identify potential safety issues before they become problems, ensuring fire doors function correctly during emergencies."
          />

          <FeatureCard
            title="Detailed Reporting"
            description="Comprehensive inspection reports provide clear documentation of compliance status and recommendations for any necessary repairs or improvements."
          />

          <FeatureCard
            title="Expert Knowledge"
            description="Qualified inspectors understand current regulations, standards, and best practices to provide accurate assessments and recommendations."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Inspection Services Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Fire Door Inspection Services
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServiceCard
            icon="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            iconColor="blue"
            title="Initial Inspections"
            description="Comprehensive baseline inspections to assess current fire door condition and compliance status."
            features={[
              "Complete door assessment",
              "Frame and hardware evaluation",
              "Compliance verification",
              "Detailed condition report",
            ]}
          />

          <ServiceCard
            icon="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
            iconColor="green"
            title="Regular Inspections"
            description="Scheduled 6-monthly inspections to monitor fire door condition and maintain compliance."
            features={[
              "6-monthly inspection schedule",
              "Wear and tear assessment",
              "Performance testing",
              "Compliance documentation",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
            iconColor="purple"
            title="Compliance Inspections"
            description="Specialized inspections focused on regulatory compliance and certification requirements."
            features={[
              "RRO 2005 compliance",
              "Building Regulations check",
              "Certification verification",
              "Regulatory reporting",
            ]}
          />

          <ServiceCard
            icon={[
              "M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z",
              "M8 5a2 2 0 012-2h4a2 2 0 012 2v2H8V5z",
            ]}
            iconColor="orange"
            title="Pre-Purchase Inspections"
            description="Detailed inspections for property purchases to identify fire safety issues and compliance status."
            features={[
              "Property purchase assessment",
              "Fire safety evaluation",
              "Cost estimation",
              "Compliance recommendations",
            ]}
          />

          <ServiceCard
            icon="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"
            iconColor="red"
            title="Emergency Inspections"
            description="Urgent inspections for safety concerns or regulatory enforcement actions."
            features={[
              "24/7 emergency callouts",
              "Safety issue assessment",
              "Immediate recommendations",
              "Priority service",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            iconColor="indigo"
            title="Certification Inspections"
            description="Specialized inspections for fire door certification and compliance documentation."
            features={[
              "Certification verification",
              "Standards compliance",
              "Documentation preparation",
              "Regulatory submission",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Inspection Process Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Inspection Process
        </h2>

        <div class="space-y-8">
          <ProcessStep
            number={1}
            title="Pre-Inspection Planning"
            description="Review of building plans, previous inspection reports, and identification of all fire doors requiring inspection."
          />

          <ProcessStep
            number={2}
            title="Comprehensive Assessment"
            description="Detailed inspection of each fire door including door leaf, frame, hardware, seals, and surrounding area."
          />

          <ProcessStep
            number={3}
            title="Compliance Verification"
            description="Verification against current regulations, standards, and building-specific requirements."
          />

          <ProcessStep
            number={4}
            title="Detailed Reporting"
            description="Comprehensive report with findings, compliance status, recommendations, and photographic evidence."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Qualifications & Experience
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <QualificationCard
            title="Professional Qualifications"
            items={[
              "FireQual Fire Door Inspector",
              "CSCS Gold Card Holder",
              "35+ Years Experience",
              "Fully Insured",
            ]}
          />

          <QualificationCard
            title="Standards & Regulations"
            items={[
              "Building Regulations Approved Document B",
              "RRO 2005 Compliance",
              "BS 9999:2017 Standards",
              "BS 8214:2016 Fire Door Assemblies",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Nearby Areas Section -->
  <section class="relative z-10 mx-auto">
    <NearbyAreas location={location} serviceType="fire-door-inspectors" />
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Book Your Fire Door Inspection
        </h2>
        <ContactForm
          location={location}
          serviceType={type}
          uniqueId={location}
        />
      </div>
    </div>
  </section>
</Layout>
