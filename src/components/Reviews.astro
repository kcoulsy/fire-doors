---
import { REVIEWS, REVIEW_COUNT, AVERAGE_RATING } from "../constants/reviews";

// Star row rounds the derived average; the numeric figure below it does not.
const averageStars = Math.round(Number(AVERAGE_RATING));

// A review is clamped if it is long enough to dominate the card. The full text is
// always in the DOM — we hide the overflow with CSS rather than swapping textContent,
// so screen readers and crawlers get the whole review and the paragraphs survive.
const CLAMP_ABOVE_CHARS = 200;
---

<section class="py-12 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">
        What My Customers Say
      </h2>

      <p class="text-gray-500 mt-4 max-w-2xl mx-auto">
        I'm proud to have earned the trust of clients across Yorkshire. Here's
        what they have to say about working with me.
      </p>

      <div class="mt-6 flex items-center justify-center gap-2 flex-wrap">
        <div class="flex text-yellow-500 text-2xl" aria-hidden="true">
          {"★".repeat(averageStars)}
        </div>
        <span class="text-gray-700 font-semibold text-lg">
          {AVERAGE_RATING} out of 5
        </span>
        <span class="text-gray-500 text-sm">
          ({REVIEW_COUNT} {REVIEW_COUNT === 1 ? "review" : "reviews"} on Google)
        </span>
        <a
          href="https://www.google.com/search?q=Coulsy+Joinery+%26+Small+Build&stick=H4sIAAAAAAAA_-NgU1I1qDCxME9KtTAzTkwySjQ0NDS1MqhItkhLsTA3SEmxAMqYGJotYpVxzi_NKa5U8MrPzEstqlRQUwjOTczJUXAqzcxJAQA2eubnSAAAAA&hl=en-GB#reviews"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-gray-500 hover:text-brand text-xs font-normal ml-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M21.35 11.1h-9.18v2.96h5.48c-.24 1.48-1.55 4.34-5.48 4.34-3.29 0-6-2.7-6-6s2.71-6 6-6c1.87 0 3.12.8 3.84 1.5l2.63-2.54C17.73 3.51 15.09 2 12 2 6.48 2 2 6.48 2 12s4.48 10 10 10c5.33 0 9.75-3.89 9.75-9.7 0-.65-.07-1.14-.16-1.6z"
            ></path>
          </svg>
          View on Google
        </a>
      </div>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto"
    >
      {
        REVIEWS.map((review, index) => {
          const bodyId = `review-${index}`;
          const paragraphs = review.text.split("\n\n");
          const isLong = review.text.length > CLAMP_ABOVE_CHARS;

          return (
            <div class="p-6 border border-gray-200 rounded-lg shadow-sm bg-white hover:shadow-md transition-shadow h-full flex flex-col">
              <div class="mb-4">
                <div class="font-semibold text-lg text-gray-900 mb-1">
                  {review.author}
                </div>
                <div
                  class="text-yellow-500 flex gap-0.5"
                  aria-label={`${review.rating} out of 5 stars`}
                >
                  <span aria-hidden="true">{"★".repeat(review.rating)}</span>
                </div>
              </div>

              <div class="flex-grow flex flex-col">
                <div
                  id={bodyId}
                  class="review-body text-gray-700 leading-relaxed flex-grow"
                  data-clamped={isLong ? "true" : "false"}
                >
                  {paragraphs.map((paragraph) => (
                    <p class="mb-3 last:mb-0">{paragraph}</p>
                  ))}
                </div>

                {isLong && (
                  <button
                    type="button"
                    class="read-more-btn mt-3 px-3 py-1 text-sm font-semibold text-brand bg-brand/10 rounded hover:bg-brand/20 transition text-left self-start"
                    data-target={bodyId}
                    aria-expanded="false"
                    aria-controls={bodyId}
                  >
                    Read more
                  </button>
                )}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  /* The whole review is in the DOM; only its overflow is hidden. */
  .review-body[data-clamped="true"] {
    max-height: 9rem;
    overflow: hidden;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".read-more-btn").forEach((button) => {
    button.addEventListener("click", () => {
      const targetId = button.getAttribute("data-target");
      const body = targetId ? document.getElementById(targetId) : null;
      if (!body) return;

      const isClamped = body.getAttribute("data-clamped") === "true";
      body.setAttribute("data-clamped", isClamped ? "false" : "true");
      button.setAttribute("aria-expanded", String(isClamped));
      button.textContent = isClamped ? "Show less" : "Read more";
    });
  });
</script>
