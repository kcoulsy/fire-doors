---
import IconCard from "./IconCard.astro";
import { CARD_LOOK } from "../config/cardLook";
import InspectorIcon from "../icons/InspectorIcon.astro";
import CardChecklist from "../icons/CardChecklist.astro";
import WrenchIcon from "../icons/WrenchIcon.astro";
import DoorOpenIcon from "../icons/DoorOpenIcon.astro";
import ExitDoorIcon from "../icons/ExitDoorIcon.astro";

const { location } = Astro.params;

function capitalizeFirstLetter(string: string) {
  return string.charAt(0).toUpperCase() + string.slice(1);
}

const services = [
  {
    Icon: InspectorIcon,
    title: "Fire Door Inspections",
    body: "FireQual-certified inspections of FD30/FD60 doors—individual doors, HMOs, blocks of flats and commercial premises—as one-off checks or planned quarterly, six-monthly and annual programmes. Includes clear advice on repair, replacement and compliance.",
  },
  {
    Icon: CardChecklist,
    title: "Fire Door Surveys & Reports",
    body: "Condition surveys, remedial and insurance reports, pre-purchase checks and specification reports—documented properly so you know exactly where you stand.",
  },
  {
    Icon: WrenchIcon,
    title: "Fire Door Repairs & Maintenance",
    body: "Closers, seals, hinges, ironmongery, gap corrections and adjustments. Most faults are small and fixable—I put them right rather than condemning the door.",
  },
  {
    Icon: DoorOpenIcon,
    title: "Fire Door Installation",
    body: "Certified installation of new timber fire doorsets—apartment entrance doors, internal fire doors and replacement doorsets, fitted to standard.",
  },
  {
    Icon: ExitDoorIcon,
    title: "Steel Fire Exit Doors",
    body: "Steel personnel and fire exit doors, panic hardware and emergency exit furniture for industrial units, factories, warehouses and schools.",
  },
];
---

<section class="bg-white py-16 md:py-24">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-2xl font-bold md:text-3xl text-brand mb-6">
        Fire Door Services I Provide
      </h2>
      <p class="mx-auto max-w-3xl text-gray-600 text-lg leading-relaxed">
        After 35 years in joinery and becoming FireQual certified, I specialise in fire door work {
          location ? `in ${capitalizeFirstLetter(location)}` : null
        }. Whether you need an inspection, a survey and report, repairs, a new timber doorset or a steel fire exit door, I'll do it properly—no shortcuts, no guesswork. I've worked on thousands of doors over the years, so I know what works and what doesn't.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {
        services.map((service) => {
          const Icon = service.Icon;
          return (
            <IconCard
              title={service.title}
              body={service.body}
              accent="navy"
              look={CARD_LOOK}
            >
              <Icon className="h-6 w-6" />
            </IconCard>
          );
        })
      }
    </div>

    <!-- Call to action -->
    <div class="mt-16 text-center">
      <div
        class="bg-gray-50 rounded-xl border border-gray-200 p-8 max-w-4xl mx-auto"
      >
        <h3 class="text-2xl font-semibold text-gray-900 mb-4">
          Need Help With Your Fire Doors?
        </h3>
        <p class="text-gray-600 mb-8 max-w-2xl mx-auto">
          I'm here to help you keep your fire doors safe and compliant. With 35 years' experience and FireQual certification, I'll give you honest advice and do the work properly. Give me a call or drop me a message.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-3 bg-brand text-white font-medium rounded-lg hover:bg-brand-light transition-all duration-300 ease-out hover:scale-105 hover:shadow-lg transform"
          >
            Get Your Quote
            <svg
              class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="/fire-door-services"
            class="inline-flex items-center justify-center px-8 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition-all duration-300 ease-out hover:scale-105 hover:shadow-lg transform"
          >
            View All Services
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
