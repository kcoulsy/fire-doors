---
// Reusable click-to-call button. Phone is the highest-converting action for a
// local trades business, so this is the primary CTA style. Derives a clean
// `tel:` href from the single source of truth in details.ts (the stored number
// has a display space that is invalid inside a tel: URI, so it is stripped here).
import { DETAILS } from "../constants/details";

interface Props {
  label?: string;
  variant?: "solid" | "outline";
  showNumber?: boolean;
  class?: string;
}

const {
  label = "Call now",
  variant = "solid",
  showNumber = true,
  class: className = "",
} = Astro.props;

const tel = DETAILS.COMPANY.PHONE.replace(/\s+/g, "");
const display = DETAILS.COMPANY.PHONE;

const base =
  "inline-flex items-center justify-center gap-2 min-h-[52px] px-6 py-3 rounded-lg font-semibold text-lg transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-green-700";
const styles =
  variant === "solid"
    ? "bg-green-700 text-white hover:bg-green-800 shadow-md"
    : "border-2 border-green-700 text-green-800 hover:bg-green-50";
---

<a href={`tel:${tel}`} class={`${base} ${styles} ${className}`}>
  <svg
    class="w-5 h-5 flex-shrink-0"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
    ></path>
  </svg>
  {showNumber ? `${label}: ${display}` : label}
</a>
