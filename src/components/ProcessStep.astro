---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="flex items-start space-x-4">
  <div
    class="flex-shrink-0 w-8 h-8 bg-brand text-white rounded-full flex items-center justify-center font-bold"
  >
    {number}
  </div>
  <div>
    <h3 class="text-xl font-semibold text-brand-900 mb-2">{title}</h3>
    <p class="text-gray-600">{description}</p>
  </div>
</div>

