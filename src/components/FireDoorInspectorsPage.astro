---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import NearbyAreas from "./NearbyAreas.astro";
import ServiceHero from "../components/ServiceHero.astro";
import heroImage from "../assets/images/inspection-survey.png";
import { Image } from "astro:assets";
import certifireImage from "../assets/images/certifire-fd30.png";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import QualificationCard from "../components/QualificationCard.astro";
import { getFormattedPageData } from "../utils/pageMeta";
import PhoneButton from "../components/PhoneButton.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ReviewSummary from "../components/ReviewSummary.astro";

interface Props {
  location?: string;
  type?: string;
}

const { location, type } = Astro.props;

const {
  locationInText,
  cleanLocationName,
  businessSchema,
  localBusinessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedDescription,
} = getFormattedPageData(location, type);

const waMessage = cleanLocationName
  ? `Hi Robert, I'd like to ask about fire door work in ${cleanLocationName}. Happy to send photos or an existing report if that helps.\n\nEnquiry via the Coulsy Fire Doors website.\n\nPostcode:\nProperty type:\nWhat's involved:`
  : `Hi Robert, I'd like to ask about fire door work. Happy to send photos or an existing report if that helps.\n\nEnquiry via the Coulsy Fire Doors website.\n\nPostcode:\nProperty type:\nWhat's involved:`;

const finalDescription = enhancedDescription || defaultDescription;
const place = cleanLocationName || "Yorkshire";
---

<Layout
  title={`Fire Door Inspections${cleanLocationName ? ` in ${cleanLocationName}` : " in Yorkshire"} | Coulsy Fire Doors`}
  description={finalDescription}
  classes="mb-16"
  location={location}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(businessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Fire Door Inspections", href: "/fire-door-inspectors" },
          ...(cleanLocationName
            ? [{ label: cleanLocationName, current: true }]
            : []),
        ]}
      />
    </div>
  </section>

  <ServiceHero
        image={heroImage}
        imageAlt="Robert checking a fire door gap during a survey"
    title={`Fire Door Inspections${location ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
    description={`I'm Robert — a FireQual qualified fire door inspector covering ${place}. I survey fire doors, write the report, and you get a document you can give straight to an insurer, Responsible Person, or enforcement officer. No shortcuts, no copy-paste.`}
    primaryCta={{ text: "Book an Inspection", link: "#contact" }}
    secondaryCta={{ text: "Contact Us", link: "/contact" }}
  />

  <!-- Why inspections matter / who I'm for -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Who an inspection is for
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          If you've had a fire risk assessment flagging doors, own an HMO,
          manage a block of flats, or run a care home, school or office —
          the Regulatory Reform Order sits on you. An inspection is the
          evidence that you've done what's expected.
        </p>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <FeatureCard
            title="Landlords and HMO owners"
            description="HMO licensing and the Fire Safety Act have made fire doors a regular enforcement target. I inspect, report, and tell you exactly what (if anything) needs fixing — in plain English, without upselling."
          />

          <FeatureCard
            title="Building managers and RPs"
            description="If you're the Responsible Person for a block, office, or care home, the buck stops with you. A written 6-monthly inspection with photos gives you a defensible paper trail."
          />

          <FeatureCard
            title="After a fire risk assessment"
            description="FRAs often flag doors but don't always say what's actually wrong. I'll go door by door and give you a practical list — what's compliant, what's borderline, and what needs doing."
          />

          <FeatureCard
            title={`Local to ${place}`}
            description={`I'm based in Yorkshire and cover ${location ? `${place} and ` : ""}the surrounding area daily. Smaller jobs can often be turned round inside a week.`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Types of inspection -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Types of inspection I carry out
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          From a single flat entrance door to a full building survey.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServiceCard
            icon="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
            title="First-time / baseline"
            description="Never had a proper inspection before? I'll go door by door and give you a full baseline — condition, compliance, and a prioritised fix list."
            features={[
              "Every door surveyed individually",
              "Photos of each item",
              "Prioritised action list",
              "Realistic cost estimate to remedy",
            ]}
          />

          <ServiceCard
            icon="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
            title="Routine 6-monthly"
            description="The regulations want fire doors checked at least every six months. I set up a recurring schedule so you don't have to chase it."
            features={[
              "6-monthly inspection contracts",
              "Wear & tear tracking over time",
              "Quick turnaround on reports",
              "Reminders before each visit",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
            title="HMO compliance"
            description="Specific inspection geared to HMO licensing — flat entrance doors, escape route doors, and anything the council might ask for."
            features={[
              "HMO-specific check list",
              "Compartmentation aware",
              "Works with your licensing officer",
              "Plain-English findings",
            ]}
          />

          <ServiceCard
            icon={[
              "M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z",
              "M8 5a2 2 0 012-2h4a2 2 0 012 2v2H8V5z",
            ]}
            title="Pre-purchase / due diligence"
            description="Buying a block, care home, or HMO? I'll walk the building and tell you what it'd cost to bring the doors up to scratch before you commit."
            features={[
              "Pre-purchase surveys",
              "Scope of works supplied",
              "Rough remediation cost",
              "Advice before exchange",
            ]}
          />

          <ServiceCard
            icon="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"
            title="Enforcement-driven"
            description="If you've had a notice from the fire service or environmental health, I can turn round a structured inspection report quickly to help you respond."
            features={[
              "Priority scheduling",
              "Report formatted for enforcement",
              "Phone support drafting response",
              "Follow-up re-inspection available",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            title="Single-door checks"
            description="Sometimes you just need one door checked — a flat entrance door, a new install, a post-repair sign-off. Happy to do that too."
            features={[
              "Single-door visits",
              "Post-repair sign-off",
              "Short-form report",
              "Fixed small-job price",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  {/* Mid-page CTA — one deliberate conversion point after the coverage grid; call primary, WhatsApp secondary */}
  <section class="py-12 bg-brand-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-brand-900 mb-2">Not sure what you need?</h2>
        <p class="text-gray-600 mb-6">
          Tell me what you're dealing with and I'll give you a straight answer
          — no obligation.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <PhoneButton label="Call now" />
          <WhatsAppButton
            variant="outline"
            label="Send details on WhatsApp"
            message={waMessage}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- How an inspection actually runs -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          What an inspection actually looks like
        </h2>

        <div class="space-y-8">
          <ProcessStep
            number={1}
            title="Quick call first"
            description="We have a ten-minute chat about the building — how many doors, what they protect, and whether there's an FRA or previous report I should see. I price from there, not from a form."
          />

          <ProcessStep
            number={2}
            title="On-site survey"
            description={`I visit ${place}, go door by door, and check each one properly — door leaf, frame, gaps, seals, hinges, closer, handle, lock, vision panel. Each item is photographed. A typical block takes half a day to a day.`}
          />

          <ProcessStep
            number={3}
            title="Written report"
            description="You get a document listing every door with its compliance status, photos of each item that's wrong, and a prioritised fix list. Insurers, RPs and enforcement officers accept it as evidence."
          />

          <ProcessStep
            number={4}
            title="Follow-up if you want it"
            description="If the fix list is fiddly I can quote to remedy it myself, or I can just hand the report over for your own contractor. No pressure to use me for both."
          />
        </div>
      </div>
    </div>
  </section>

  {/* Proof: a real certified door — the Certifire label check. Robert to verify wording. */}
  <section class="py-14 bg-gray-50">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-center">
        <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm">
          <Image
            src={certifireImage}
            alt="Certifire FD30 certified fire door component label on a doorset"
            widths={[400, 600, 800]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="w-full h-auto"
            loading="lazy"
            quality={80}
            format="webp"
          />
        </div>
        <div>
          <h2 class="text-2xl lg:text-3xl font-bold text-brand-900 mb-4">
            I check the certification, not just the door
          </h2>
          <p class="text-gray-600 mb-3">
            Every fire door should carry a certification label — a Certifire or
            BM&nbsp;Trada mark showing the leaf is a tested FD30 or FD60 component.
          </p>
          <p class="text-gray-600">
            On each inspection I find the label, check the reference is genuine and
            matches the doorset, and record it with a photo in your report. A missing
            label, or components that don't match the certificate, is a finding — and
            it's exactly what fails an audit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Qualifications and standards
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          The bits that matter when an insurer or RP asks who surveyed your
          doors.
        </p>

        <div class="grid md:grid-cols-2 gap-8">
          <QualificationCard
            title="My qualifications"
            items={[
              "FireQual Fire Door Inspector",
              "CSCS Gold Card holder",
              "City & Guilds qualified (since 1989)",
              "Fully insured, VAT registered",
            ]}
          />

          <QualificationCard
            title="Standards I work to"
            items={[
              "Approved Document B (Building Regs)",
              "Regulatory Reform (Fire Safety) Order 2005",
              "BS 8214:2016 — fire door assemblies",
              "BS 9999:2017 — fire safety in buildings",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 mx-auto">
    <NearbyAreas location={location} serviceType="fire-door-inspectors" />
  </section>

  <ReviewSummary />

  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Book an inspection
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Tell me roughly how many doors and where they are — I'll come
          back with a straight quote and a sensible visit date.
        </p>
        <ContactForm
          showHeader={false}
          location={location}
          serviceType={type}
          uniqueId={location}
        />
      </div>
    </div>
  </section>
</Layout>
