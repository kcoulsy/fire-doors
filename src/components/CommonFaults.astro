---
// Common fire door failures — a grouped defect taxonomy.
// A full FD30/FD30S survey reports against ~60 granular failure types across the
// whole doorset; these 12 grouped categories are the public-facing summary,
// mapped to the BS 8214 / FDIS survey structure. Icon-free by design: for fatal
// defects a wrong glyph reads worse than none, so each card carries only a red
// severity rule.
const faults = [
  {
    title: "Missing Certification & Labelling",
    body: "With no label or plug on the door edge there's no evidence it's a certified fire door — or that the leaf and frame were tested together.",
  },
  {
    title: "Door Leaf Damage & Warping",
    body: "Splits, holes or a bowed, twisted leaf break the fire-resisting construction and stop the door sealing against the frame.",
  },
  {
    title: "Frame & Fire-Stopping Defects",
    body: "A loose or out-of-square frame, or an unsealed gap between frame and wall, lets fire bypass the doorset even when the door is sound.",
  },
  {
    title: "Excessive or Uneven Gaps",
    body: "Gaps around the leaf should sit at a consistent 2–4mm. Too wide lets smoke and fire through; too tight and the door binds and won't close.",
  },
  {
    title: "Threshold Gap & Smoke Leakage",
    body: "An oversized gap under the door, or a missing drop or threshold seal, lets cold smoke pass — usually the first thing to spread in a fire.",
  },
  {
    title: "Missing or Damaged Seals",
    body: "Intumescent and smoke seals that are missing, painted over or damaged can't expand to close the gaps — so the door never reaches its rating.",
  },
  {
    title: "Hinge & Fixing Faults",
    body: "Fewer than three hinges, the wrong hinge type, or missing and loose screws let the door drop and warp, breaking the seal against the frame.",
  },
  {
    title: "Self-Closing Failure",
    body: "A fire door must close fully and latch from any angle. A missing, damaged or under-powered closer leaves it standing open when it matters most.",
  },
  {
    title: "Latching, Locks & Ironmongery",
    body: "Non-fire-rated latches, locks or handles — or a latch that won't hold the door shut against the closer — stop the doorset performing.",
  },
  {
    title: "Glazing & Vision Panels",
    body: "Non-fire-rated glass, damaged beading, or a vision panel cut in on site can't hold back fire — and voids the door's certification.",
  },
  {
    title: "Unauthorised Alterations & Obstructions",
    body: "Letterplates, cat flaps, extra locks or spy holes added after certification — or a door wedged and propped open — void the rating.",
  },
  {
    title: "Signage & Ongoing Maintenance",
    body: "Missing 'Fire Door Keep Shut' signage, and a lack of routine maintenance, mean faults go unnoticed and unmanaged over time.",
  },
];
---

<section class="container mx-auto bg-gray-50">
  <div
    class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8 lg:py-16"
  >
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold md:text-3xl text-brand mb-4">
        Common Fire Door Failures
      </h2>

      <p class="mt-4 text-gray-600 text-lg leading-relaxed">
        A fire door only holds back fire as a complete assembly—leaf, frame,
        seals, hinges, closer and glazing all have to be right. A full survey can
        record up to 70 individual defects; the categories below group the ones
        I find most often, and any single one can stop the door doing its job.
      </p>
    </div>

    <div
      class="mt-12 grid grid-cols-1 gap-6 md:gap-8 md:grid-cols-2 lg:grid-cols-3"
    >
      {
        faults.map((fault) => (
          <div class="group bg-white rounded-xl border border-gray-200 border-l-4 border-l-red-600 p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 ease-out">
            <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-brand transition-colors duration-300">
              {fault.title}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">{fault.body}</p>
          </div>
        ))
      }
    </div>

    <!-- Call to action -->
    <div class="mt-12 text-center">
      <div class="bg-white rounded-lg border border-gray-200 p-8 shadow-sm">
        <h3 class="text-xl font-semibold text-gray-900 mb-4">
          Concerned About Your Fire Doors?
        </h3>
        <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
          Don't wait until it's too late. I can spot these issues quickly—I've seen them all before. Most are easy fixes if caught early, but they can become expensive problems if left. I'll check everything properly and tell you exactly what needs doing.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center px-6 py-3 bg-brand text-white font-medium rounded-lg hover:bg-brand-light transition-all duration-300 ease-out hover:scale-105 hover:shadow-lg transform"
        >
          Book a Fire Door Inspection
          <svg
            class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
