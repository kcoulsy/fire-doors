---
import Layout from "../layouts/Layout.astro";
import ServiceHero from "../components/ServiceHero.astro";
import heroImage from "../assets/images/robert-coulson-fire-door-specialist.png";
import WhyFireDoors from "./WhyFireDoors.astro";
import CommonFaults from "./CommonFaults.astro";
import MainServices from "./MainServices.astro";
import FireStats from "./FireStats.astro";
import Reviews from "./Reviews.astro";

const { location } = Astro.params;

// Modern SEO optimization with personal voice preserved
const seoData = {
  title:
    "Coulsy Fire Door Services - Professional Fire Door Inspection & Installation in Yorkshire",
  description:
    "Expert fire door services in Yorkshire including inspections, installation, maintenance and compliance. Family-run business, on the tools since 1989. FireQual certified fire door inspector.",
  keywords:
    "fire door services Yorkshire, fire door inspection, fire door installation, fire safety compliance, fire door maintenance, Robert Coulson fire doors",
  canonical: "https://coulsyfiredoors.co.uk",
  structuredData: {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: "Coulsy Fire Door Services",
    description:
      "Professional fire door services in Yorkshire including inspections, installation, maintenance and compliance.",
    url: "https://coulsyfiredoors.co.uk",
    telephone: "+44 7544 030486",
    email: "robert@coulsy.co.uk",
    address: {
      "@type": "PostalAddress",
      addressLocality: "York",
      addressRegion: "Yorkshire",
      addressCountry: "GB",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: "53.9590",
      longitude: "-1.0792",
    },
    openingHours: ["Mo-Fr 08:00-18:00", "Sa 09:00-16:00"],
    priceRange: "££",
    areaServed: ["York", "Wetherby", "Harrogate", "Yorkshire"],
    serviceArea: {
      "@type": "GeoCircle",
      geoMidpoint: {
        "@type": "GeoCoordinates",
        latitude: "53.9590",
        longitude: "-1.0792",
      },
      geoRadius: "50000",
    },
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Fire Door Services",
      itemListElement: [
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Fire Door Inspection",
            description: "Professional fire door compliance inspections",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Fire Door Installation",
            description: "Expert fire door installation and fitting",
          },
        },
        {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: "Fire Door Maintenance",
            description: "Ongoing fire door maintenance and repair",
          },
        },
      ],
    },
    foundingDate: "1989",
    founder: {
      "@type": "Person",
      name: "Robert Coulson",
      jobTitle: "Fire Door Specialist",
      description:
        "City & Guilds qualified joiner since 1989; FireQual fire door inspector since 2024",
    },
    employee: [
      {
        "@type": "Person",
        name: "Robert Coulson",
        jobTitle: "Fire Door Specialist",
        description:
          "City & Guilds qualified joiner since 1989; FireQual fire door inspector since 2024",
      },
    ],
    // No aggregateRating: the 4.8/50 that used to sit here was invented, and a
    // business may not claim review stars about itself. See constants/reviews.ts.
    award: [
      "FireQual Fire Door Inspector",
      "CSCS Gold Card Holder",
      "NVQ Level 7 in Construction Senior Management",
      "Advanced City & Guilds in Carpentry & Joinery (Distinction)",
    ],
    brand: {
      "@type": "Brand",
      name: "Coulsy Fire Door Services",
      slogan: "Fire Safety Excellence in Yorkshire",
    },
  },
};
---

<Layout
  title={seoData.title}
  description={seoData.description}
  classes="mb-16"
>
  {/* Hero — photo panel with Robert's portrait, consistent with the service pages */}
  <ServiceHero
    image={heroImage}
    imageAlt="Robert Coulson, FireQual fire door inspector, Yorkshire"
    title="Professional Fire Door Services in Yorkshire"
    description="I'm Robert — a City & Guilds joiner with Distinction, FireQual fire door inspector and Clerk of Works. Fire door inspections, installation and maintenance across Yorkshire — no sales team, no subcontracting, you deal with me from first call to final report."
    primaryCta={{ text: "Get a Quote", link: "/contact" }}
    secondaryCta={{ text: "View all services", link: "/fire-door-services" }}
    whatsAppMessage={`Hi Robert, I'd like to ask about fire door work. Happy to send photos or an existing report if that helps.\n\nEnquiry via the Coulsy Fire Doors website.\n\nPostcode:\nProperty type:\nWhat's involved:`}
  />

  <!-- Why Fire Doors Section -->
  <section class="relative z-10 mx-auto">
    <WhyFireDoors />
  </section>

  <!-- Services Section -->
  <section class="relative z-10 mx-auto">
    <MainServices location={location} />
  </section>

  <!-- Common Faults Section -->
  <section class="relative z-10 mx-auto">
    <CommonFaults />
  </section>

  <!-- Fire Statistics Section -->
  <section class="relative z-10 mx-auto">
    <FireStats />
  </section>

  <!-- Testimonials Section -->
  <section class="relative z-10 mx-auto">
    <Reviews />
  </section>
</Layout>

<!-- Note: Structured data (LocalBusiness schema) is handled in Layout.astro to avoid duplicates -->
