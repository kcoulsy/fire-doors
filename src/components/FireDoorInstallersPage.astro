---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import NearbyAreas from "./NearbyAreas.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import QualificationCard from "../components/QualificationCard.astro";
import { getFormattedPageData } from "../utils/pageMeta";

interface Props {
  location?: string;
  type?: string;
}

const { location, type } = Astro.props;

const {
  formattedServiceName,
  locationInText,
  cleanLocationName,
  businessSchema,
  localBusinessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedDescription,
} = getFormattedPageData(location, type);

const finalDescription = enhancedDescription || defaultDescription;
---

<Layout
  title={`${formattedServiceName} ${cleanLocationName ? `in ${cleanLocationName}` : "in Yorkshire"} | Professional Fire Door Installation`}
  description={finalDescription}
  classes="mt-8 mb-16"
  location={location}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(businessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />
  <!-- Breadcrumb -->
  <section class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Fire Door Installers", href: "/fire-door-installers" },
          ...(cleanLocationName
            ? [{ label: cleanLocationName, current: true }]
            : []),
        ]}
      />
    </div>
  </section>

  <ServiceHero
    title={`Fire Door Installation Services${cleanLocationName ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
    description="Qualified fire door installation services to ensure your fire doors are fitted correctly and meet all regulatory requirements. From supply to installation and certification, we handle every aspect of your fire door project."
    primaryCta={{ text: "Get Installation Quote", link: "#contact" }}
    secondaryCta={{ text: "Contact Us", link: "/contact" }}
  />

  <!-- Why Professional Installation Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Why Professional Fire Door Installation is Critical
        </h2>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <FeatureCard
            title="Safety & Compliance"
            description="Incorrect installation can compromise fire door performance and fail to meet Building Regulations and fire safety standards, putting occupants at risk."
          />

          <FeatureCard
            title="Performance Assurance"
            description="Professional installation ensures fire doors function correctly during emergencies, providing the intended fire resistance and smoke protection."
          />

          <FeatureCard
            title="Warranty Protection"
            description="Manufacturer warranties often require professional installation. DIY or unqualified installation can void warranty coverage."
          />

          <FeatureCard
            title="Long-term Reliability"
            description="Proper installation extends fire door lifespan and reduces maintenance costs while ensuring continued compliance and safety."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Services Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Fire Door Installation Services
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServiceCard
            icon="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
            iconColor="blue"
            title="Supply & Installation"
            description="Complete supply and professional installation of fire doors and doorsets to meet your specifications."
            features={[
              "Fire door supply",
              "Professional installation",
              "Hardware fitting",
              "Quality assurance",
            ]}
          />

          <ServiceCard
            icon="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
            iconColor="green"
            title="New Build Installation"
            description="Fire door installation for new buildings, ensuring compliance with current building regulations."
            features={[
              "New construction projects",
              "Building regulations compliance",
              "Project coordination",
              "Completion certification",
            ]}
          />

          <ServiceCard
            icon={[
              "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
              "M15 12a3 3 0 11-6 0 3 3 0 016 0z",
            ]}
            iconColor="purple"
            title="Retrofit Installation"
            description="Upgrading existing doors to fire door standards or replacing non-compliant fire doors."
            features={[
              "Existing building upgrades",
              "Door replacement",
              "Frame modifications",
              "Minimal disruption",
            ]}
          />

          <ServiceCard
            icon="M13 10V3L4 14h7v7l9-11h-7z"
            iconColor="orange"
            title="Specialist Installations"
            description="Installation of specialist fire doors including acoustic, security, and accessibility features."
            features={[
              "Acoustic fire doors",
              "Security fire doors",
              "Accessibility features",
              "Custom specifications",
            ]}
          />

          <ServiceCard
            icon="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
            iconColor="red"
            title="Hardware Installation"
            description="Professional installation of fire-rated hardware including closers, locks, and seals."
            features={[
              "Door closers",
              "Fire-rated locks",
              "Intumescent seals",
              "Smoke seals",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            iconColor="indigo"
            title="Certification & Testing"
            description="Post-installation testing and certification to ensure fire doors meet all performance requirements."
            features={[
              "Performance testing",
              "Compliance verification",
              "Certification documentation",
              "Handover reports",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Process Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Installation Process
        </h2>

        <div class="space-y-8">
          <ProcessStep
            number={1}
            title="Site Survey & Planning"
            description="Comprehensive site survey to assess requirements, measure openings, and plan the installation process."
          />

          <ProcessStep
            number={2}
            title="Specification & Supply"
            description="Specification of appropriate fire doors and hardware, followed by supply of certified products."
          />

          <ProcessStep
            number={3}
            title="Professional Installation"
            description="Qualified installation by experienced technicians following manufacturer guidelines and regulations."
          />

          <ProcessStep
            number={4}
            title="Testing & Certification"
            description="Post-installation testing and certification to ensure fire doors meet all performance requirements."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Our Qualifications & Experience
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <QualificationCard
            title="Professional Qualifications"
            items={[
              "CSCS Gold Card Holder",
              "FireQual Fire Door Inspector",
              "35+ Years Experience",
              "Fully Insured",
            ]}
          />

          <QualificationCard
            title="Standards & Compliance"
            items={[
              "Building Regulations Approved Document B",
              "BS 8214:2016 Fire Door Assemblies",
              "Manufacturer Guidelines",
              "Quality Assurance Procedures",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Nearby Areas Section -->
  <section class="relative z-10 mx-auto">
    <NearbyAreas location={location} serviceType="fire-door-installers" />
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          Get Your Fire Door Installation Quote
        </h2>
        <ContactForm
          location={location}
          serviceType={type}
          uniqueId={location}
        />
      </div>
    </div>
  </section>
</Layout>
