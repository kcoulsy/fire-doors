---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import robertProfileImage from "../assets/images/team/robert-profile-image.jpg";
import teamOnSiteImage from "../assets/images/team/Rob-and-Debbie-on-site.jpg";
import debbieProfileImage from "../assets/images/team/debbie-profile-image.jpg";
import timberJoineryImage from "../assets/images/timber20joinery.jpg";
import complianceImage from "../assets/images/compliance.jpeg";
import doorHangingImage from "../assets/images/door-hanging-1.jpeg";
import benchPlaneImage from "../assets/images/bench-plane-frog.jpg";
import Reviews from "../components/Reviews.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import SisterSiteCard from "../components/SisterSiteCard.astro";
import { COULSY_JOINERY } from "../constants/sisterSites";

// Modern SEO optimization with personal voice preserved
const seoData = {
  title:
    "About Robert Coulson - Coulsy Ltd | Joiner Since 1989, FireQual Fire Door Inspector",
  description:
    "Meet Robert Coulson - runs Coulsy Ltd for joinery and small build works, now specialising in fire doors after passing FireQual exams in December 2024. 35+ years of joinery experience behind it.",
  keywords:
    "Robert Coulson Coulsy Ltd, joinery specialist Yorkshire, fire door specialist 2024, FireQual certified, Coulsy joinery, fire safety expert",
  canonical: "https://coulsyfiredoors.co.uk/about",
  structuredData: {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: "About Robert Coulson - Coulsy Ltd Joinery & Fire Door Specialist",
    description:
      "Runs Coulsy Ltd for joinery and small build works, now specialising in fire doors after passing FireQual exams in December 2024",
    url: "https://coulsyfiredoors.co.uk/about",
    mainEntity: {
      // "Organization" — schema.org type names are US-spelled and are identifiers,
      // not prose. A UK spelling pass had changed this to "Organisation", which is
      // not a schema.org type, so the whole node was ignored. Site copy stays UK.
      "@type": "Organization",
      name: "Coulsy Fire Door Services",
      founder: {
        "@type": "Person",
        name: "Robert Coulson",
        jobTitle: "Joiner & Fire Door Specialist",
        description:
          "Runs Coulsy Ltd for joinery and small build works, now specialising in fire doors after passing FireQual exams in December 2024",
        url: "https://www.linkedin.com/in/robert-coulson-20a60915/",
      },
      employee: [
        {
          "@type": "Person",
          name: "Robert Coulson",
          jobTitle: "Joiner & Fire Door Specialist",
          description:
            "Runs Coulsy Ltd for joinery and small build works, now specialising in fire doors after passing FireQual exams in December 2024",
        },
      ],
      foundingDate: "1989",
      description:
        "Coulsy Ltd for joinery and small build works, now specialising in fire doors with FireQual certification",
    },
  },
};
---

<Layout title={seoData.title} description={seoData.description}>
  <main class="mx-auto relative z-10">
    <section class="w-full container mx-auto px-4 sm:px-6 pt-4 pb-8">
      <Breadcrumb crumbs={[{ label: "About", current: true }]} />

      <!-- Header Section with Enhanced Animation -->
      <div class="text-center mb-16">
        <h1
          class="text-4xl lg:text-6xl font-bold text-brand-900 mb-6 text-balance about-title"
        >
          About Our Fire Door Services
        </h1>
        <p
          class="text-xl text-brand-600 max-w-4xl mx-auto text-balance leading-relaxed about-subtitle"
        >
          Professional fire door services backed by over three decades of
          joinery and building experience. We specialise in fire door
          installation, maintenance, inspections, and ensuring full compliance
          with fire safety regulations across Yorkshire.
        </p>
      </div>

      <!-- What We Do For Clients Section -->
      <div class="mb-20">
        <h2
          class="text-3xl lg:text-4xl font-bold text-brand-900 mb-12 text-center services-title"
        >
          What I Can Do For You
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Fire Door Installation -->
          <div
            class="service-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden rounded-lg mb-6">
              <Image
                src={doorHangingImage}
                width={300}
                height={200}
                class="w-full h-48 object-cover transition-transform duration-500 hover:scale-110"
                alt="Professional fire door installation services"
                loading="lazy"
                decoding="async"
                format="webp"
                quality={80}
              />
            </div>
            <h3 class="text-xl font-bold text-brand-900 mb-4">
              Fire Door Installation
            </h3>
            <p class="text-brand-600 leading-relaxed">
              I've fitted thousands of fire doors over the years, so I know how to do it properly. I ensure proper fitting, compliance, and long-term performance—no shortcuts, everything done to standard.
            </p>
          </div>

          <!-- Fire Door Inspections -->
          <div
            class="service-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden rounded-lg mb-6">
              <Image
                src={benchPlaneImage}
                width={300}
                height={200}
                class="w-full h-48 object-cover transition-transform duration-500 hover:scale-110"
                alt="Professional fire door inspection services"
                loading="lazy"
                decoding="async"
                format="webp"
                quality={80}
              />
            </div>
            <h3 class="text-xl font-bold text-brand-900 mb-4">
              Fire Door Inspections
            </h3>
            <p class="text-brand-600 leading-relaxed">
              As a FireQual certified inspector, I'll check everything properly and identify compliance issues. I provide detailed reports and recommendations—no jargon, just clear advice on what needs doing.
            </p>
          </div>

          <!-- Fire Door Maintenance -->
          <div
            class="service-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden rounded-lg mb-6">
              <Image
                src={timberJoineryImage}
                width={300}
                height={200}
                class="w-full h-48 object-cover transition-transform duration-500 hover:scale-110"
                alt="Professional fire door maintenance services"
                loading="lazy"
                decoding="async"
                format="webp"
                quality={80}
              />
            </div>
            <h3 class="text-xl font-bold text-brand-900 mb-4">
              Fire Door Maintenance
            </h3>
            <p class="text-brand-600 leading-relaxed">
              I'll keep your fire doors in optimal condition with regular maintenance. I check everything properly—closers, seals, gaps—to ensure doors continue to function correctly and maintain their fire resistance rating.
            </p>
          </div>
        </div>
      </div>

      <!-- Why Choose Us Section -->
      <div class="mb-20">
        <h2
          class="text-3xl lg:text-4xl font-bold text-brand-900 mb-12 text-center why-choose-title"
        >
          Why Choose Our Fire Door Services
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div
            class="why-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center mr-4"
              >
                <svg
                  class="w-6 h-6 text-brand-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-brand-900">
                FireQual Certified
              </h3>
            </div>
            <p class="text-brand-600 leading-relaxed">
              I passed all FireQual exams in December 2024 because I wanted to be properly qualified. When you work with me, you're getting a certified fire door specialist who knows what they're doing.
            </p>
          </div>

          <div
            class="why-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center mr-4"
              >
                <svg
                  class="w-6 h-6 text-brand-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-brand-900">
                35+ Years Experience
              </h3>
            </div>
            <p class="text-brand-600 leading-relaxed">
              I've been on the tools for over three decades—thousands of fire doors fitted over the years. I've seen what works and what doesn't, so you can trust my experience.
            </p>
          </div>

          <div
            class="why-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center mr-4"
              >
                <svg
                  class="w-6 h-6 text-brand-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-brand-900">Full Compliance</h3>
            </div>
            <p class="text-brand-600 leading-relaxed">
              I make sure your fire doors meet all current fire safety regulations and building standards. I don't cut corners when it comes to safety—people's lives depend on these doors working properly.
            </p>
          </div>

          <div
            class="why-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500"
          >
            <div class="flex items-center mb-4">
              <div
                class="w-12 h-12 bg-brand-100 rounded-lg flex items-center justify-center mr-4"
              >
                <svg
                  class="w-6 h-6 text-brand-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  ></path>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-brand-900">Personal Service</h3>
            </div>
            <p class="text-brand-600 leading-relaxed">
              You'll deal with me directly—no call centres, no middlemen. I'm an experienced professional who takes pride in quality workmanship and attention to detail. When you call, you speak to me.
            </p>
          </div>
        </div>
      </div>

      <!-- About Robert Section -->
      <div class="mb-20">
        <h2
          class="text-3xl lg:text-4xl font-bold text-brand-900 mb-12 text-center about-robert-title"
        >
          About Robert Coulson
        </h2>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
          <!-- Profile Image -->
          <div class="lg:col-span-1">
            <div
              class="profile-card bg-white rounded-2xl p-6 shadow-xl border border-brand-100 overflow-hidden"
            >
              <div class="relative overflow-hidden rounded-xl">
                <Image
                  src={robertProfileImage}
                  width={400}
                  height={500}
                  class="w-full h-auto object-cover transition-transform duration-700 hover:scale-110"
                  alt="Robert Coulson - joiner since 1989, FireQual fire door inspector since 2024"
                  loading="eager"
                  decoding="async"
                  format="webp"
                  quality={90}
                />
                <div
                  class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 hover:opacity-100 transition-opacity duration-500"
                >
                </div>
              </div>
              <div class="mt-6 text-center">
                <h3 class="text-2xl font-bold text-brand-900 mb-2">
                  Robert Coulson
                </h3>
                <p class="text-brand-600 font-medium">
                  Joiner & Fire Door Specialist
                </p>
                <p class="text-sm text-brand-500 mt-1">Joiner since 1989</p>
                <p class="text-xs text-brand-400 mt-1">
                  FireQual Certified - Dec 2024
                </p>
                <p class="text-xs text-brand-400 mt-1">
                  ICWCI membership assessment — passed
                </p>
              </div>
            </div>
          </div>

          <!-- Timeline -->
          <div class="lg:col-span-2">
            <div class="timeline-container space-y-8">
              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <h3 class="text-2xl font-bold text-brand-900 mb-2">
                    1989 - The Beginning
                  </h3>
                  <p class="text-brand-600 leading-relaxed">
                    Started my journey in joinery and building, developing
                    exceptional craftsmanship skills and attention to detail
                    that would become the foundation of everything I do.
                  </p>
                </div>
              </div>

              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <h3 class="text-2xl font-bold text-brand-900 mb-2">
                    1990s - Building Excellence
                  </h3>
                  <p class="text-brand-600 leading-relaxed">
                    I established Coulsy Ltd and worked on high-end residential and
                    commercial projects, perfecting traditional joinery
                    techniques and modern construction methods. This is where I learned to do things properly, not cut corners.
                  </p>
                </div>
              </div>

              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <h3 class="text-2xl font-bold text-brand-900 mb-2">
                    2000s - Fire Door Experience
                  </h3>
                  <p class="text-brand-600 leading-relaxed">
                    I fitted thousands of fire doors over the years as part of
                    general joinery work, gaining extensive hands-on experience
                    with fire safety requirements. I learned what works and what doesn't through real-world experience.
                  </p>
                </div>
              </div>

              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <h3 class="text-2xl font-bold text-brand-900 mb-2">
                    December 2024 - FireQual Certification
                  </h3>
                  <p class="text-brand-600 leading-relaxed">
                    After seeing appalling workmanship in the fire door
                    industry—doors fitted wrong, seals missing, gaps too big—I decided to specialise properly. I passed all the FireQual exams because I wanted to be the person who does it right. Now when I inspect a door, I'm checking everything properly, not rushing through like some do.
                  </p>
                </div>
              </div>

              <div class="timeline-item">
                <div class="timeline-marker"></div>
                <div class="timeline-content">
                  <h3 class="text-2xl font-bold text-brand-900 mb-2">
                    Clerk of Works / Construction Inspection
                  </h3>
                  <p class="text-brand-600 leading-relaxed">
                    I have passed the ICWCI membership assessment for Clerk of
                    Works. Membership remains subject to election. The discipline
                    centres on independent inspection, quality assurance and
                    evidence-based reporting across construction projects. Those
                    same principles underpin my fire-door inspection work.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contextual hand-off: this site owns fire doors; wider joinery is another
           Coulsy website. Deliberately subordinate to the fire door CTAs. -->
      <div class="mb-20">
        <SisterSiteCard
          site={COULSY_JOINERY}
          heading="Need wider joinery or building work?"
          reason="Fire doors are my specialist focus here — including inspection, compliance and remedial work. For wider joinery, refurbishment or small building projects, visit Coulsy Joinery & Small Build, our dedicated Coulsy website for that work."
          cta="Visit Coulsy Joinery"
        />
      </div>

      <!-- Expertise Grid -->
      <div class="mb-20">
        <h2
          class="text-3xl lg:text-4xl font-bold text-brand-900 mb-12 text-center expertise-title"
        >
          Areas of Expertise
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {/* A joiner first. This card is PROVENANCE, not a service offer: it is
              why the fire door work can be trusted, not an invitation to book
              joinery. Wider joinery is handed off to the joinery site above.
              JSX comment, not <!-- -->: Astro renders HTML comments to production. */}
          <div
            class="expertise-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden rounded-lg mb-6">
              <Image
                src={benchPlaneImage}
                width={300}
                height={200}
                class="w-full h-48 object-cover transition-transform duration-500 hover:scale-110"
                alt="Hand tools on the bench — the joinery background behind the fire door work"
                loading="lazy"
                decoding="async"
                format="webp"
                quality={80}
              />
            </div>
            <h3 class="text-xl font-bold text-brand-900 mb-4">
              A Joiner First
            </h3>
            <p class="text-brand-600 leading-relaxed">
              City &amp; Guilds qualified in carpentry and joinery — Craft with
              Distinction, then Advanced with Distinction. I bring decades of
              practical experience on the tools to every fire door inspection and
              installation. Understanding how a door and frame are made is
              fundamental to recognising why a fire door has failed, and what is
              required to put it right.
            </p>
          </div>

          <!-- Fire Door Specialisation -->
          <div
            class="expertise-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden rounded-lg mb-6">
              <Image
                src={doorHangingImage}
                width={300}
                height={200}
                class="w-full h-48 object-cover transition-transform duration-500 hover:scale-110"
                alt="Professional fire door installation and hanging"
                loading="lazy"
                decoding="async"
                format="webp"
                quality={80}
              />
            </div>
            <h3 class="text-xl font-bold text-brand-900 mb-4">
              Fire Door Specialisation
            </h3>
            <p class="text-brand-600 leading-relaxed">
              FireQual certified since December 2024. Fitted thousands of fire
              doors over the years, now specialising in installation,
              maintenance, and inspections with formal certification.
            </p>
          </div>

          {/* Was a small-build sales card — present-tense selling of building work
              from a fire door site. Replaced with a real fire door expertise area.
              Small build work belongs to the joinery site.
              JSX comment, not <!-- -->: Astro renders HTML comments to production. */}
          <div
            class="expertise-card bg-white rounded-xl p-8 shadow-lg border border-brand-100 hover:shadow-xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden rounded-lg mb-6">
              <Image
                src={complianceImage}
                width={300}
                height={200}
                class="w-full h-48 object-cover transition-transform duration-500 hover:scale-110"
                alt="Fire door compliance documentation and inspection records"
                loading="lazy"
                decoding="async"
                format="webp"
                quality={80}
              />
            </div>
            <h3 class="text-xl font-bold text-brand-900 mb-4">
              Inspection &amp; Compliance
            </h3>
            <p class="text-brand-600 leading-relaxed">
              I carry out detailed fire door inspections covering the door leaf,
              frame, seals, gaps, hinges, closer and ironmongery. Findings are
              recorded in a clear written report, with defects and recommended
              remedial actions set out plainly for the client or Responsible
              Person.
            </p>
          </div>
        </div>
      </div>

      <!-- Team Section Enhanced -->
      <div class="mb-20">
        <h2
          class="text-3xl lg:text-4xl font-bold text-brand-900 mb-12 text-center team-title"
        >
          Our Team
        </h2>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-2 max-w-4xl mx-auto">
          <!-- Robert Card Enhanced -->
          <div
            class="team-card group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden">
              <Image
                src={robertProfileImage}
                alt="Robert Coulson - Distinguished joiner and fire door specialist"
                loading="eager"
                width={400}
                height={300}
                class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-110"
                decoding="async"
                format="webp"
                quality={90}
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              >
              </div>
              <div
                class="absolute bottom-0 left-0 right-0 p-4 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500"
              >
                <h3 class="text-xl font-bold text-white mb-1">
                  Robert Coulson
                </h3>
                <p class="text-sm text-gray-200 mb-2">
                  Distinguished Joiner & Fire Door Specialist
                </p>
                <p class="text-xs text-gray-300">Joiner since 1989</p>
              </div>
            </div>
            <div class="p-6">
              <p class="text-brand-600 mb-4 leading-relaxed">
                Joiner with 35+ years of experience. Runs Coulsy Ltd for joinery
                and small build works, now FireQual certified fire door
                specialist since December 2024.
              </p>
              <a
                target="_blank"
                href="https://www.linkedin.com/in/robert-coulson-20a60915/"
                rel="noopener"
                class="inline-flex items-center text-brand-600 hover:text-brand-700 transition-all duration-300 hover:scale-105"
              >
                <svg
                  class="h-5 w-5 mr-2 transition-transform duration-300 group-hover:translate-x-1"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M16.338 16.338h33.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h3.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1h3.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h35.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z"
                  ></path>
                </svg>
                <span class="text-sm font-medium">Connect with Robert</span>
              </a>
            </div>
          </div>

          <!-- Team Working Card Enhanced -->
          <div
            class="team-card group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden"
          >
            <div class="relative overflow-hidden">
              <Image
                src={teamOnSiteImage}
                alt="Robert and Debbie on site during fire door work"
                loading="eager"
                width={400}
                height={300}
                class="w-full h-64 object-cover transition-transform duration-700 group-hover:scale-110"
                decoding="async"
                format="webp"
                quality={90}
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              >
              </div>
              <div
                class="absolute bottom-0 left-0 right-0 p-4 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500"
              >
                <h3 class="text-xl font-bold text-white mb-1">
                  Fire Door Inspection &amp; Compliance
                </h3>
                <p class="text-sm text-gray-200 mb-2">FireQual certified</p>
