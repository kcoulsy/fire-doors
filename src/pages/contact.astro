---
import ContactForm from "../components/ContactForm.astro";
import EnvelopeIcon from "../icons/EnvelopeIcon.astro";
import PhoneIcon from "../icons/PhoneIcon.astro";
import PhoneButton from "../components/PhoneButton.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import Reviews from "../components/Reviews.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact Us" classes="mt-8 mb-16">
  <div class="container mx-auto px-4 max-w-6xl py-6">
    {/* Header */}
    <div class="max-w-2xl">
      <h1 class="text-4xl font-bold text-brand-900 mb-3">Get in touch</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Happy to talk through your fire doors — whether it's a quick question or
        a full inspection. No hard sell, just straight advice.
      </p>
    </div>

    {/* Fastest ways to reach me: call + WhatsApp are the primary actions */}
    <div
      class="mt-8 rounded-2xl border border-brand-100 bg-brand-50 p-6 sm:p-8"
    >
      <p
        class="text-xs font-semibold uppercase tracking-wider text-brand-600 mb-4"
      >
        Fastest ways to reach me
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <PhoneButton label="Call now" class="flex-1" />
        <WhatsAppButton class="flex-1" />
      </div>
      <p class="text-sm text-gray-600 mt-4">
        No obligation, and I usually reply the same day. Happy to take a
        look at photos over WhatsApp before we arrange a visit.
      </p>
    </div>

    {/* Form + service-area / company details */}
    <div class="mt-10 grid lg:grid-cols-3 gap-8 items-start">
      <div class="lg:col-span-2">
        <ContactForm
          title="Send me a message"
          subtitle="Tell me a bit about your doors and I'll come back to you — usually the same day."
        />
      </div>

      <div class="space-y-6">
        {/* Where I work (service-area, not a premises) */}
        <div class="rounded-xl border border-gray-200 bg-white p-6">
          <div class="flex items-center gap-2 mb-3">
            <svg
              class="w-5 h-5 flex-shrink-0 text-brand-600"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <h2 class="text-lg font-bold text-brand-900">Where I work</h2>
          </div>
          <p class="text-sm text-gray-600 mb-4">
            I come to you. I work across York, Harrogate, Leeds, Ripon and the
            surrounding Yorkshire towns and villages — inspections, surveys and
            remedial work carried out at your property. If you're not sure I
            cover your area, just ask.
          </p>
          <ul class="space-y-2 text-sm">
            <li class="flex items-center gap-2">
              <PhoneIcon className="h-4 w-4 flex-shrink-0 text-brand-600" />
              <a href="tel:07544030486" class="text-brand-700 hover:text-brand"
                >07544 030486</a
              >
            </li>
            <li class="flex items-center gap-2">
              <EnvelopeIcon className="h-4 w-4 flex-shrink-0 text-brand-600" />
              <a
                href="mailto:robert@coulsy.co.uk"
                class="text-brand-700 hover:text-brand">robert@coulsy.co.uk</a
              >
            </li>
          </ul>
        </div>

        {/* Why choose me — Fire Doors provenance only (verified) */}
        <div class="rounded-xl border border-brand-100 bg-brand-50 p-6">
          <h2 class="text-lg font-bold text-brand-900 mb-4">Why choose me?</h2>
          <ul class="space-y-3 text-sm text-brand-700">
            <li class="flex items-start gap-3">
              <span
                class="flex-shrink-0 w-2 h-2 rounded-full bg-brand-600 mt-1.5"
              ></span>
              <span
                ><strong class="text-brand-900">You deal directly with me.</strong
                > No call centre and no sales team — Robert, start to finish.</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="flex-shrink-0 w-2 h-2 rounded-full bg-brand-600 mt-1.5"
              ></span>
              <span
                ><strong class="text-brand-900"
                  >FireQual certified inspector.</strong
                > Qualified in December 2024, and a CSCS Gold Card holder.</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="flex-shrink-0 w-2 h-2 rounded-full bg-brand-600 mt-1.5"
              ></span>
              <span
                ><strong class="text-brand-900">35+ years on the tools.</strong> A
                City &amp; Guilds joiner before I specialised in fire doors, so I
                know how a door is built.</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span
                class="flex-shrink-0 w-2 h-2 rounded-full bg-brand-600 mt-1.5"
              ></span>
              <span
                ><strong class="text-brand-900">Clear written reports.</strong> A
                record you can hand to an insurer, Responsible Person or building
                control.</span
              >
            </li>
          </ul>
        </div>

        {/* Business details — concise; full registered office on /company-information */}
        <div class="rounded-xl border border-gray-200 bg-white p-6">
          <h2 class="text-lg font-bold text-brand-900 mb-2">Business details</h2>
          <p class="text-sm text-gray-500 mb-4">
            For your peace of mind — a VAT-registered UK limited company.
          </p>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="font-semibold text-brand-900">Registered company</dt>
              <dd class="text-gray-600">Coulsy Limited</dd>
            </div>
            <div>
              <dt class="font-semibold text-brand-900">Company number</dt>
              <dd class="text-gray-600">08575688</dd>
            </div>
            <div>
              <dt class="font-semibold text-brand-900">VAT registration number</dt>
              <dd class="text-gray-600">168340989</dd>
            </div>
          </dl>
          <a
            href="/company-information"
            class="inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700 mt-4"
            >Company information →</a
          >
        </div>
      </div>
    </div>
  </div>

  {/* Social proof */}
  <Reviews />
</Layout>
