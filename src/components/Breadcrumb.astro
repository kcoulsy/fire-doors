---
// Breadcrumb.astro
interface Crumb {
  label: string;
  href?: string;
  current?: boolean;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

// Generate structured data for breadcrumbs (Context7/Astro best practice)
const breadcrumbStructuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: Astro.site?.href || "https://coulsyfiredoors.co.uk",
    },
    ...crumbs.map((crumb, index) => ({
      "@type": "ListItem",
      position: index + 2,
      name: crumb.label,
      item: crumb.href
        ? `${Astro.site?.href || "https://coulsyfiredoors.co.uk"}${crumb.href}`
        : Astro.url.href,
    })),
  ],
};
---

<nav class="text-sm sm:text-base pb-4 min-h-[2.5rem]" aria-label="Breadcrumb">
  <ol
    class="list-none p-0 flex flex-wrap items-center space-x-2 min-h-[2.75rem]"
  >
    <li class="flex items-center">
      <a
        href="/"
        id="home-icon"
        class="inline-flex items-center cursor-pointer hover:opacity-80 rounded transition-opacity duration-300 mr-1"
        aria-label="Home"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#47525d"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4 h-4 sm:w-5 sm:h-5"
          aria-hidden="true"
        >
          <path
            d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
          ></path>
        </svg>
      </a>
      <span class="mx-2">/</span>
    </li>
    {
      crumbs.map((crumb, index) => (
        <li class="flex items-center">
          {crumb.current || (!crumb.href && index === crumbs.length - 1) ? (
            <span class="text-[#596574]">{crumb.label}</span>
          ) : (
            <a
              href={crumb.href}
              class="px-1 py-1 text-[#2a3b4f] hover:text-black rounded transition-colors duration-300"
            >
              {crumb.label}
            </a>
          )}
          {index < crumbs.length - 1 && <span class="mx-2">/</span>}
        </li>
      ))
    }
  </ol>
</nav>


<!-- Breadcrumb Structured Data (Context7/Astro SEO best practice) -->
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(breadcrumbStructuredData)}
/>
