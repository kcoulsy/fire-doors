    }

    async handleSearch(query) {
      if (!query.trim()) {
        this.hideResults();
        return;
      }

      // Clear previous timeout
      if (this.searchTimeout) {
        clearTimeout(this.searchTimeout);
      }

      // Debounce search
      this.searchTimeout = setTimeout(async () => {
        await this.performSearch(query);
      }, 300);
    }

    async performSearch(query) {
      this.showLoading();

      try {
        // Simulate AI-powered semantic search
        const results = await this.semanticSearch(query);
        this.displayResults(results);
      } catch (error) {
        console.error("Search error:", error);
        this.showNoResults();
      }
    }

    async semanticSearch(query) {
      // Enhanced AI semantic search with location and type matching
      const queryLower = query.toLowerCase().trim();
      const queryWords = queryLower.split(/\s+/);
      const results = [];

      // Check for location in query
      const locations = [
        "york",
        "leeds",
        "harrogate",
        "wetherby",
        "ripon",
        "selby",
        "knaresborough",
        "tadcaster",
        "pocklington",
        "yorkshire",
      ];
      const queryLocation = locations.find((loc) =>
        queryLower.includes(loc)
      );

      for (const page of this.searchIndex) {
        let score = 0;

        // Exact title match (highest weight)
        if (page.title.toLowerCase() === queryLower) {
          score += 20;
        } else if (page.title.toLowerCase().includes(queryLower)) {
          score += 12;
        }

        // Word-by-word title matching
        const titleWords = page.title.toLowerCase().split(/\s+/);
        const matchingTitleWords = queryWords.filter((qw) =>
          titleWords.some((tw) => tw.includes(qw) || qw.includes(tw))
        ).length;
        score += matchingTitleWords * 3;

        // Content match
        if (page.content.toLowerCase().includes(queryLower)) {
          score += 6;
        }

        // Keyword match (exact)
        for (const keyword of page.keywords) {
          if (keyword.toLowerCase() === queryLower) {
            score += 5;
          } else if (keyword.toLowerCase().includes(queryLower)) {
            score += 3;
          } else if (queryLower.includes(keyword.toLowerCase())) {
            score += 2;
          }
        }

        // Location boost (if location matches)
        if (queryLocation && page.type === "location") {
          if (page.url.includes(queryLocation)) {
            score += 8;
          }
        }

        // Type boost (service vs page vs FAQ)
        if (queryWords.some((qw) => ["service", "services"].includes(qw))) {
          if (page.type === "service") score += 3;
        }
        if (
          queryWords.some((qw) => ["question", "faq", "help", "answer"].includes(qw))
        ) {
          if (page.type === "faq") score += 4;
        }

        // Semantic similarity (expanded)
        const semanticKeywords = this.getSemanticKeywords(query);
        for (const semanticKeyword of semanticKeywords) {
          if (page.content.toLowerCase().includes(semanticKeyword)) {
            score += 2;
          }
          if (page.keywords.some((k) => k.toLowerCase().includes(semanticKeyword))) {
            score += 1.5;
          }
        }

        // Partial word matches
        for (const word of queryWords) {
          if (word.length > 3) {
            // Only check words longer than 3 characters
            if (page.title.toLowerCase().includes(word)) {
              score += 1;
            }
            if (page.content.toLowerCase().includes(word)) {
              score += 0.5;
            }
          }
        }

        if (score > 0) {
          results.push({ ...page, score });
        }
      }

      // Sort by relevance score and return top results
      return results.sort((a, b) => b.score - a.score).slice(0, 8);
    }

    getSemanticKeywords(query) {
      // Enhanced AI semantic understanding with more mappings
      const queryLower = query.toLowerCase();
      const semanticMap = {
        // Service-related
        install: ["installation", "fitting", "mount", "installer", "fitted"],
        maintain: ["maintenance", "repair", "service", "servicing", "upkeep"],
        inspect: [
          "inspection",
          "check",
          "audit",
          "survey",
          "inspector",
          "inspections",
        ],
        // Fire door related
        fire: ["fire safety", "fire door", "fire protection", "fireproof"],
        door: ["fire door", "entrance", "exit", "doors", "doorway"],
        safety: ["fire safety", "compliance", "regulation", "safe", "secure"],
        // Location-related
        yorkshire: ["york", "leeds", "harrogate", "yorkshire"],
        york: ["yorkshire", "york"],
        // Cost-related
        cost: ["price", "pricing", "costs", "quote", "quotes", "charge", "fee"],
        price: ["cost", "pricing", "costs", "quote", "quotes", "charge", "fee"],
        cheap: ["affordable", "competitive", "cost", "price"],
        // Question-related
        how: ["how to", "how do", "how much", "how often"],
        what: ["what is", "what are", "what does"],
        why: ["why do", "why is"],
        // Qualification-related
        qualified: ["certified", "certification", "qualifications", "certificate"],
        certified: ["qualified", "qualifications", "certification", "certificate"],
        // Emergency-related
        emergency: ["urgent", "callout", "emergency", "asap", "immediate"],
        urgent: ["emergency", "callout", "urgent", "immediate"],
      };

      const keywords = [];
      for (const [key, values] of Object.entries(semanticMap)) {
        if (queryLower.includes(key)) {
          keywords.push(...values);
        }
      }

      // Also check for common question patterns
      if (queryLower.match(/how much|how many|how often|how long/)) {
        keywords.push("cost", "price", "pricing", "quote");
      }

      return keywords;
    }

    displayResults(results) {
      this.hideLoading();

      if (results.length === 0) {
        this.showNoResults();
        return;
      }

      // Get type icons and badges
      const getTypeIcon = (type) => {
        if (type === "service") {
          return `<svg class="w-4 h-4 text-brand" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
          </svg>`;
        } else if (type === "location") {
          return `<svg class="w-4 h-4 text-brand" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
          </svg>`;
        } else if (type === "faq") {
          return `<svg class="w-4 h-4 text-brand" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
          </svg>`;
        }
        return `<svg class="w-4 h-4 text-brand" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
          <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
        </svg>`;
      };

      const getTypeBadge = (type) => {
        if (type === "service") return "Service";
        if (type === "location") return "Location";
        if (type === "faq") return "FAQ";
        return "Page";
      };

      this.content.innerHTML = results
        .map(
          (result) => `
        <a href="${result.url}" class="block p-4 hover:bg-gray-50 transition-colors">
          <div class="flex items-start space-x-3">
            <div class="flex-shrink-0">
              <div class="w-8 h-8 bg-brand/10 rounded-lg flex items-center justify-center">
                ${getTypeIcon(result.type)}
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
              <p class="text-sm font-medium text-gray-900 truncate">
                ${result.title}
              </p>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
                  ${getTypeBadge(result.type)}
                </span>
              </div>
              <p class="text-sm text-gray-500 line-clamp-2">
                ${result.content}
              </p>
            </div>
          </div>
        </a>
      `
        )
        .join("");

      this.showResults();
    }

    showLoading() {
      this.loading?.classList.remove("hidden");
      this.content?.classList.add("hidden");
      this.noResults?.classList.add("hidden");
      this.showResults();
    }

    hideLoading() {
      this.loading?.classList.add("hidden");
      this.content?.classList.remove("hidden");
    }

    showNoResults() {
      this.hideLoading();
      this.noResults?.classList.remove("hidden");
      this.content?.classList.add("hidden");
      this.showResults();
    }

    showResults() {
      this.results?.classList.remove("hidden");
    }

    hideResults() {
      this.results?.classList.add("hidden");
    }

    handleKeyboardNavigation(e) {
      const results = this.results?.querySelectorAll("a");
      if (!results) return;

      const currentIndex = Array.from(results).findIndex(
        (result) => result === document.activeElement
      );

      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          const nextIndex =
            currentIndex < results.length - 1 ? currentIndex + 1 : 0;
          results[nextIndex]?.focus();
          break;
        case "ArrowUp":
          e.preventDefault();
          const prevIndex =
            currentIndex > 0 ? currentIndex - 1 : results.length - 1;
          results[prevIndex]?.focus();
          break;
        case "Escape":
          this.hideResults();
          this.input?.blur();
          break;
      }
    }
  }

  // Initialize AI Smart Search
  document.addEventListener("DOMContentLoaded", () => {
    new AISmartSearch();
  });
</script>

<style>
  /* Search animations */
  #search-results {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Focus styles */
  #ai-search-input:focus {
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }

  /* Base styles */
  #ai-search-input {
    transition:
      color 0.3s ease,
      background-color 0.3s ease,
      border-color 0.3s ease;
  }

  /* Placeholder colors */
  #ai-search-input::placeholder {
    color: #6b7280;
  }
</style>
