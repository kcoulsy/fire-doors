---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import NearbyAreas from "./NearbyAreas.astro";
import ServiceHero from "../components/ServiceHero.astro";
import heroImage from "../assets/images/door-hanging-1.jpeg";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import QualificationCard from "../components/QualificationCard.astro";
import { getFormattedPageData } from "../utils/pageMeta";
import PhoneButton from "../components/PhoneButton.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import ReviewSummary from "../components/ReviewSummary.astro";

interface Props {
  location?: string;
  type?: string;
}

const { location, type } = Astro.props;

const {
  locationInText,
  cleanLocationName,
  businessSchema,
  localBusinessSchema,
  serviceSchema,
  faqSchema,
  defaultDescription,
  enhancedDescription,
} = getFormattedPageData(location, type);

const waMessage = cleanLocationName
  ? `Hi Robert, I'd like to ask about fire door work in ${cleanLocationName}. Happy to send photos or an existing report if that helps.\n\nEnquiry via the Coulsy Fire Doors website.\n\nPostcode:\nProperty type:\nWhat's involved:`
  : `Hi Robert, I'd like to ask about fire door work. Happy to send photos or an existing report if that helps.\n\nEnquiry via the Coulsy Fire Doors website.\n\nPostcode:\nProperty type:\nWhat's involved:`;

const finalDescription = enhancedDescription || defaultDescription;
const place = cleanLocationName || "Yorkshire";
---

<Layout
  title={`Fire Door Installation${cleanLocationName ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
  description={finalDescription}
  classes="mb-16"
  location={location}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(businessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(localBusinessSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <section class="bg-gray-50 pt-4">
    <div class="container mx-auto px-4">
      <Breadcrumb
        crumbs={[
          { label: "Fire Door Services", href: "/fire-door-services" },
          { label: "Fire Door Installation", href: "/fire-door-installers" },
          ...(cleanLocationName
            ? [{ label: cleanLocationName, current: true }]
            : []),
        ]}
      />
    </div>
  </section>

  <ServiceHero
        image={heroImage}
        imageAlt="Fitting a fire door"
    title={`Fire Door Installation${location ? ` in ${cleanLocationName}` : " in Yorkshire"}`}
    description={`I'm Robert — a City & Guilds qualified joiner, on the tools since 1988, and a FireQual fire door inspector. I fit fire doors and doorsets across ${place}: flats, HMOs, care homes, schools, offices. Correct doors, correct ironmongery, proper paperwork at the end.`}
    primaryCta={{ text: "Get an Installation Quote", link: "#contact" }}
    secondaryCta={{ text: "Contact Us", link: "/contact" }}
    whatsAppMessage={waMessage}
  />

  <!-- Why get the install right / who I work for -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          A fire door is only as good as the install
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          The certified 30-minute rating assumes the door, frame, seals and
          ironmongery are installed exactly as tested. Get the gaps, hinges
          or closer wrong and you've spent money on a door that won't
          perform. I've hung doors for over 30 years — I know where these
          installs tend to fall down.
        </p>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <FeatureCard
            title="Tested as a doorset"
            description="I fit certified doorsets — door, frame, seals and ironmongery matched to the test evidence. That's what insurers and building control want to see, not a fire door dropped into a random frame."
          />

          <FeatureCard
            title="Gaps, seals, closers done right"
            description="The install detail — 3mm gaps, proper intumescent and smoke seals, a correctly-adjusted closer, hinges rated for the door weight — is what makes the rating real. It's the bit a non-specialist trade tends to fudge."
          />

          <FeatureCard
            title="Certification paperwork"
            description="You get the manufacturer's certificate, my install sign-off, and (for commercial jobs) a handover pack referencing BS 8214 / Approved Document B. Ready for building control, insurer or RP."
          />

          <FeatureCard
            title={`Local to ${place}`}
            description={`I'm based in Yorkshire and cover ${location ? `${place} and ` : ""}the region daily. Small jobs can often be booked within a week or two; larger fit-outs I schedule properly so there's no stop-start.`}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What I install -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          What I install
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Single-door swaps up to full building fit-outs. Not making the
          doors — fitting them, to spec.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServiceCard
            icon="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
            title="FD30 / FD60 doorsets"
            description="Certified doorsets for flats, corridors, escape routes and stairwells. Supplied and fitted as a matched unit."
            features={[
              "FD30 — 30 minute rating",
              "FD60 — 60 minute rating",
              "Matched frame and ironmongery",
              "Manufacturer certificate supplied",
            ]}
          />

          <ServiceCard
            icon="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
            title="New build & refurb"
            description="Working from architect's specs on new-build blocks, or fitting as part of an HMO / care home refurb. Happy to work alongside main contractors or directly for the client."
            features={[
              "New build projects",
              "HMO and care home refits",
              "School and office fit-outs",
              "Coordinates with main contractor",
            ]}
          />

          <ServiceCard
            icon={[
              "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z",
              "M15 12a3 3 0 11-6 0 3 3 0 016 0z",
            ]}
            title="Retrofit / replacement"
            description="Taking out a non-compliant door and frame and fitting the right doorset. The usual job for older blocks failing a fire risk assessment."
            features={[
              "Failed-FRA remediation",
              "Old flat entrance upgrades",
              "Frame replacement where needed",
              "Tidy make-good of wall & finish",
            ]}
          />

          <ServiceCard
            icon="M13 10V3L4 14h7v7l9-11h-7z"
            title="Single-door installs"
            description="Sometimes it's just one door — a damaged flat entrance, a new office meeting room, a one-off replacement. Happy to take on the small jobs."
            features={[
              "One-off replacements",
              "Post-damage make-safe",
              "Landlord flat entrance upgrades",
              "Clear small-job pricing",
            ]}
          />

          <ServiceCard
            icon="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"
            title="Ironmongery & hardware"
            description="Closers, hinges, locks, seals — the bits that have to be right for the rating to hold. Whether it's a full set or swapping out a dead closer."
            features={[
              "Fire-rated hinges & closers",
              "Intumescent & smoke seals",
              "Certified locks & handles",
              "Correct for door weight & use",
            ]}
          />

          <ServiceCard
            icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            title="Handover & sign-off"
            description="Post-install check, photos, and the paperwork an insurer, RP or building control will want. Clean handover, no chasing me for docs later."
            features={[
              "Install sign-off document",
              "Photos of each doorset",
              "Manufacturer certificates",
              "Gap and closer check record",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  {/* Mid-page CTA — one deliberate conversion point after the coverage grid; call primary, WhatsApp secondary */}
  <section class="py-12 bg-brand-50">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-brand-900 mb-2">Not sure what you need?</h2>
        <p class="text-gray-600 mb-6">
          Tell me what you're dealing with and I'll give you a straight answer
          — no obligation.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <PhoneButton label="Call now" />
          <WhatsAppButton
            variant="outline"
            label="Send details on WhatsApp"
            message={waMessage}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- How a fit-out runs -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-12">
          How a fit-out runs
        </h2>

        <div class="space-y-8">
          <ProcessStep
            number={1}
            title="Survey and spec"
            description={`I come out to ${place}, measure each opening, and agree the spec — FD30 or FD60, ironmongery, finish, any fire-stopping round the frame. I'd rather spend an hour getting this right than turn up on day one and find the doors don't fit.`}
          />

          <ProcessStep
            number={2}
            title="Order and schedule"
            description="Certified doorsets get ordered from the manufacturer with matched ironmongery. Lead time depends on the supplier — usually 2–4 weeks. I give you a realistic install date and stick to it."
          />

          <ProcessStep
            number={3}
            title="On-site install"
            description="I fit each doorset properly — correct gaps, plumb, level, seals continuous, closer set for the door weight, hinges rated. Tenants or staff in the building? I work around them and I clean up after myself."
          />

          <ProcessStep
            number={4}
            title="Sign-off pack"
            description="You get a handover pack — manufacturer certificate per doorset, my install sign-off, photos, and a gap/closer check record. Hand it to building control, the RP, or the insurer without chasing me for docs."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Qualifications and standards
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          The bits that matter when building control or an insurer asks who
          fitted your doors.
        </p>

        <div class="grid md:grid-cols-2 gap-8">
          <QualificationCard
            title="My qualifications"
            items={[
              "City & Guilds qualified joiner",
              "FireQual Fire Door Inspector",
              "CSCS Gold Card holder",
              "Fully insured, VAT registered",
            ]}
          />

          <QualificationCard
            title="Standards I work to"
            items={[
              "Approved Document B (Building Regs)",
              "Regulatory Reform (Fire Safety) Order 2005",
              "BS 8214:2016 — fire door assemblies",
              "BS 9999:2017 — fire safety in buildings",
            ]}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="relative z-10 mx-auto">
    <NearbyAreas location={location} serviceType="fire-door-installers" />
  </section>

  <ReviewSummary />

  <section id="contact" class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-brand-900 mb-4">
          Get a quote
        </h2>
        <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
          Tell me roughly how many doors, what kind of building, and
          whether there's a spec already — I'll come back with a realistic
          scope and price.
        </p>
        <ContactForm
          showHeader={false}
          location={location}
          serviceType={type}
          uniqueId={location}
        />
      </div>
    </div>
  </section>
</Layout>
